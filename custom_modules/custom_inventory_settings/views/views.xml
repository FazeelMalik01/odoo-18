<odoo>
  <record id="view_stock_picking_form_inherit_employee" model="ir.ui.view">
    <field name="name">stock.picking.form.inherit.employee</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
      <!-- Insert after picking_type_id field -->
      <xpath expr="//field[@name='picking_type_id']" position="after">
        <field name="employee_id" options="{'no_open': True}"  readonly="state == 'done'" />
      </xpath>
    </field>
  </record>
  <record id="view_move_line_tree_inherit_price" model="ir.ui.view">
    <field name="name">stock.move.line.tree.inherit.price</field>
    <field name="model">stock.move.line</field>
    <field name="inherit_id" ref="stock.view_move_line_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='product_id']" position="after">
        <field name="product_cost" optional="show"/>
      </xpath>
    </field>
  </record>
</odoo>