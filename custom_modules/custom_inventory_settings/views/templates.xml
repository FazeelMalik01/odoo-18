<odoo>
  <record id="view_employee_pin_wizard_form" model="ir.ui.view">
    <field name="name">employee.pin.wizard.form</field>
    <field name="model">employee.pin.wizard</field>
    <field name="arch" type="xml">
      <form string="Enter PIN" create="0" edit="0">
        <group>
          <field name="employee_id"/>
          <field name="entered_pin" password="True"/>
        </group>
        <footer>
          <button string="Confirm" type="object" name="action_confirm_pin" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>