<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide the default Tasks card -->
    <template id="portal_my_home_hide_tasks" name="Portal Home - Hide Tasks Card" inherit_id="project.portal_my_home" priority="50">
        <xpath expr="//div[@id='portal_service_category']/t[@t-call='portal.portal_docs_entry'][2]" position="replace"/>
    </template>

    <!-- Add "All task" card to portal home -->
    <template id="portal_my_home_all_task" name="Portal Home - All Task Card" inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[@id='portal_service_category']" position="inside">
            <div class="o_portal_index_card col-md-6 order-2">
                <a t-attf-href="/all/task"
                   class="d-flex gap-2 gap-md-3 py-3 pe-md-3 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_index_card_icon">
                        <img src="/custom_progress_report/static/src/img/tasks.svg" alt="All task" style="width: 64px; height: 64px;"/>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-normal">All task</h5>
                        <p class="text-muted mb-0">Follow and comments tasks of your projects</p>
                    </div>
                </a>
            </div>
        </xpath>
    </template>
</odoo>

