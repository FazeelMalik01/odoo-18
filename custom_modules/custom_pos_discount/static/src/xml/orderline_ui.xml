<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_pos_add.Orderline" 
   t-inherit="point_of_sale.Orderline" 
   t-inherit-mode="extension">
        <xpath expr="//div[@class='d-flex justify-content-between']" position="before">
            <div t-if="props.line.barcode" class="product-barcode" style="font-size: 0.8rem; color: #666; margin-bottom: 2px;">
                <span>Barcode: </span>
                <span t-esc="props.line.barcode"/>
            </div>
        </xpath>
        <!-- <xpath expr="//t[@t-slot='default']" position="after">
            <li class="custom-currency-off" t-if="props.line.discount">
                <span>Discount: </span>
                <t t-esc="props.line.discount + '%'"/>
            </li>
        </xpath> -->
    </t>
</templates>