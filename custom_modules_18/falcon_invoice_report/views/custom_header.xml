    </template>
    <template id="external_layout_wave" inherit_id="web.external_layout_wave">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
    <template id="external_layout_folder" inherit_id="web.external_layout_folder">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
</odoo>