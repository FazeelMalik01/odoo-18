<odoo>
    <template id="custom_header">
        <div class="header">
            <div class="text-center">
                <img src='/falcon_invoice_report/static/src/img/header_blue.png' style="width:100%;"/>
            </div>
        </div>
    </template>
    <template id="external_layout_standard" inherit_id="web.external_layout_standard">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
    <template id="external_layout_boxed" inherit_id="web.external_layout_boxed">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
    <template id="external_layout_bold" inherit_id="web.external_layout_bold">
