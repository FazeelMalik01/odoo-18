            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
    <template id="xternal_layout_striped" inherit_id="web.external_layout_striped">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <t t-call="falcon_invoice_report.custom_header"/>
        </xpath>
    </template>
    <template id="external_layout_bubble" inherit_id="web.external_layout_bubble">
