<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add "Service Request" Card to Portal Home -->
    <template id="portal_my_home_inherit_service_request" inherit_id="portal.portal_my_home" name="Service Request Portal Card">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <div class="o_portal_category row g-2 mt-3" id="portal_service_request_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/service_request_portal/static/src/img/service-request.svg'"/>
                    <t t-set="title">Service Requests</t>
                    <t t-set="text">Manage your service requests</t>
                    <t t-set="url" t-value="'/my/service_requests'"/>
                </t>
            </div>
        </xpath>
    </template>

    <!-- Service Request List View -->
    <template id="portal_service_request_list" name="Portal Service Request List">
        <t t-call="portal.portal_layout">
            <t t-set="title">Service Requests</t>
            <t t-set="breadcrumb" t-value="[('Home', '/my'), ('Service Requests', '/my/service_requests')]"/>
            <div class="container mt-3">
                <!-- Page Header -->
                <div class="row mb-4">
                    <div class="col">
                        <h2 class="mb-0">My Service Requests</h2>
                        <p class="text-muted">View and manage your service requests</p>
                    </div>
                    <div class="col-auto">
                        <a href="/my/service_requests/new" class="btn btn-primary">
                            <i class="fa fa-plus me-2"></i>New Service Request
                        </a>
                    </div>
                </div>

                <!-- Service Requests Table -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Service Requests</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">Reference</th>
                                        <th scope="col">Requested Date</th>
                                        <th scope="col">Service Location</th>
                                        <th scope="col">Status</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="service_requests" t-as="sr">
                                        <tr>
                                            <td><strong t-esc="sr.name"/></td>
                                            <td>
                                                <t t-if="sr.requested_appointment">
                                                    <span t-esc="sr.requested_appointment"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted">Not specified</span>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-if="sr.service_location">
                                                    <span t-esc="sr.service_location.replace('_', ' ').title()"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted">-</span>
                                                </t>
                                            </td>
                                            <td>
                                                <span t-attf-class="badge
                                                    #{sr.state == 'draft' and 'bg-secondary' or ''}
                                                    #{sr.state == 'submitted' and 'bg-info' or ''}
                                                    #{sr.state == 'in_progress' and 'bg-warning' or ''}
                                                    #{sr.state == 'completed' and 'bg-success' or ''}
                                                    #{sr.state == 'cancelled' and 'bg-danger' or ''}">
                                                    <t t-raw="sr.state.replace('_', ' ').title()"/>
                                                </span>
                                            </td>
                                            <td>
                                                <a t-attf-href="/my/service_requests/#{sr.id}" class="btn btn-sm btn-outline-primary">
                                                    View Details
                                                </a>
                                            </td>
                                        </tr>
                                    </t>

                                    <t t-if="not service_requests">
                                        <tr>
                                            <td colspan="5" class="text-center py-4">
                                                <div class="text-muted">
                                                    <i class="fa fa-clipboard-list fa-3x mb-3"></i>
                                                    <p class="mb-0">No service requests found.</p>
                                                    <a href="/my/service_requests/new" class="btn btn-sm btn-primary mt-2">
                                                        Create Your First Service Request
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                <t t-if="pager">
                    <div class="row mt-4">
                        <div class="col">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">
                                    <!-- Prev -->
                                    <li t-if="pager.get('page_previous')" class="page-item">
                                        <a class="page-link" t-attf-href="#{pager['page_previous']['url']}">
                                            <i class="fa fa-chevron-left me-1"></i> Previous
                                        </a>
                                    </li>
                                    <!-- Numbers -->
                                    <t t-foreach="pager.get('pages', [])" t-as="page_obj">
                                        <li t-att-class="'page-item ' + ('active' if page_obj['num'] == pager['page']['num'] else '')">
                                            <a class="page-link" t-attf-href="#{page_obj['url']}" t-esc="page_obj['num']"/>
                                        </li>
                                    </t>
                                    <!-- Next -->
                                    <li t-if="pager.get('page_next')" class="page-item">
                                        <a class="page-link" t-attf-href="#{pager['page_next']['url']}">
                                            Next <i class="fa fa-chevron-right ms-1"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </t>

                <div class="row mt-4">
                    <div class="col">
                        <a href="/my" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-2"></i> Back to Portal
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Service Request Form -->
    <template id="portal_service_request_form" name="Portal Service Request Form">
        <t t-call="portal.portal_layout">
            <t t-set="title">New Service Request</t>
            <t t-set="breadcrumb" t-value="[('Home', '/my'), ('Service Requests', '/my/service_requests'), ('New Request', False)]"/>
            <div class="o_portal_wrap container my-5">
                <div class="card shadow-sm p-4">
                    <h2 class="mb-4">Service Request Form</h2>

                    <form action="/my/service_requests/submit" method="post" class="needs-validation" novalidate="novalidate">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <!-- Customer Info -->
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Name</label>
                                <input type="text" name="name" class="form-control" t-att-value="partner.name" readonly="readonly"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Company</label>
                                <input type="text" name="company_partner_id" class="form-control" t-att-value="company_name"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Service Address</label>
                                 <textarea name="service_address" class="form-control" rows="2"><t t-esc="service_address"/></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">City</label>
                                 <input type="text" name="city" class="form-control" t-att-value="city"/>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">State</label>
                                <input type="text" name="state_name" class="form-control" t-att-value="state_name"/>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">ZIP</label>
                                <input type="text" name="zip" class="form-control" t-att-value="zip_code"/>
                            </div>
                        </div>

                        <hr class="my-4"/>

                        <!-- Contact Details -->
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Primary Phone</label>
                                <input type="text" name="primary_phone" class="form-control"  t-att-value="primary_phone"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" name="email" class="form-control" readonly="1" t-att-value="email"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Requested Appointment</label>
                                <input type="datetime-local" name="requested_appointment" class="form-control"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Preferred Contact Method</label>
                                <select name="preferred_contact_method" class="form-select">
                                    <option value="">Select</option>
                                    <option value="phone">Phone</option>
                                    <option value="text">Text</option>
                                    <option value="email">Email</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4"/>

                        <!-- Service Type -->
                        <div class="mb-4">
                            <h5 class="fw-semibold">Service Type</h5>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Product</label>
                                <select name="product_id" class="form-select">
                                    <option value="">Select Product</option>
                                    <t t-foreach="products" t-as="prod">
                                        <option t-att-value="prod.id" t-esc="prod.display_name"/>
                                    </t>
                                </select>
                            </div>
                            <input type="text" name="service_type_other_details" class="form-control mt-2" placeholder="Other service details"/>
                        </div>

                        <hr class="my-4"/>

                        <!-- Service Location -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Service Location</label>
                                <select name="service_location" class="form-select">
                                    <option value="">Select</option>
                                    <option value="residential">Residential</option>
                                    <option value="commercial">Commercial</option>
                                    <option value="industrial">Industrial</option>
                                    <option value="government">Government / Restricted Facility</option>
                                </select>
                            </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description of Issue or Request</label>
                            <textarea name="description" class="form-control" rows="4"></textarea>
                        </div>

                        <!-- Access Instructions -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Gate Code / Access Details</label>
                            <input type="text" name="gate_code" class="form-control"/>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" name="pets_on_site" id="pets_on_site"/>
                            <label for="pets_on_site" class="form-check-label">Dogs / Pets on site?</label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Technician Notes</label>
                            <textarea name="technician_notes" class="form-control" rows="3"></textarea>
                        </div>

                        <!-- Billing Address -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Billing Address</label>
                            <textarea name="billing_address" class="form-control" rows="2"></textarea>
                        </div>

                        <hr class="my-4"/>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fa fa-paper-plane me-2"></i>Submit Request
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- Service Request Detail View -->
    <template id="portal_service_request_detail" name="Portal Service Request Detail">
        <t t-call="portal.portal_layout">
            <t t-set="title" t-value="'Service Request - ' + service_request.name"/>
            <t t-set="breadcrumb" t-value="[('Home', '/my'), ('Service Requests', '/my/service_requests'), (service_request.name, False)]"/>
            <div class="container mt-3">
                <!-- Header -->
                <div class="row mb-4">
                    <div class="col">
                        <a href="/my/service_requests" class="btn btn-outline-secondary btn-sm mb-3">
                            <i class="fa fa-arrow-left me-2"></i> Back to List
                        </a>
                        <h2 class="mb-1">Service Request: <span t-esc="service_request.name"/></h2>
                        <p class="text-muted mb-0">
                            Status: 
                            <span t-attf-class="badge
                                #{service_request.state == 'draft' and 'bg-secondary' or ''}
                                #{service_request.state == 'submitted' and 'bg-info' or ''}
                                #{service_request.state == 'in_progress' and 'bg-warning' or ''}
                                #{service_request.state == 'completed' and 'bg-success' or ''}
                                #{service_request.state == 'cancelled' and 'bg-danger' or ''}">
                                <t t-raw="service_request.state.replace('_', ' ').title()"/>
                            </span>
                        </p>
                    </div>
                </div>

                <!-- Service Request Details -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Request Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Customer</label>
                                <p class="mb-0" t-esc="service_request.customer_id.name if service_request.customer_id else 'N/A'"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Company</label>
                                <p class="mb-0" t-esc="service_request.company_partner_id.name if service_request.company_partner_id else 'N/A'"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Service Address</label>
                                <p class="mb-0" t-esc="service_request.service_address or 'N/A'"/>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">City</label>
                                <p class="mb-0" t-esc="service_request.city or 'N/A'"/>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">State</label>
                                <p class="mb-0" t-esc="service_request.state_id.name if service_request.state_id else 'N/A'"/>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">ZIP</label>
                                <p class="mb-0" t-esc="service_request.zip or 'N/A'"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Requested Appointment</label>
                                <p class="mb-0">
                                    <t t-if="service_request.requested_appointment">
                                        <span t-esc="service_request.requested_appointment"/>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted">Not specified</span>
                                    </t>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Preferred Contact Method</label>
                                <p class="mb-0" t-esc="service_request.preferred_contact_method.replace('_', ' ').title() if service_request.preferred_contact_method else 'N/A'"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Service Location</label>
                                <p class="mb-0" t-esc="service_request.service_location.replace('_', ' ').title() if service_request.service_location else 'N/A'"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Pets on Site</label>
                                <p class="mb-0">
                                    <t t-if="service_request.pets_on_site">Yes</t>
                                    <t t-else="">No</t>
                                </p>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Description of Issue or Request</label>
                                <p class="mb-0" t-esc="service_request.description or 'N/A'"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Gate Code / Access Details</label>
                                <p class="mb-0" t-esc="service_request.gate_code or 'N/A'"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Technician Notes</label>
                                <p class="mb-0" t-esc="service_request.technician_notes or 'N/A'"/>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Billing Address</label>
                                <p class="mb-0" t-esc="service_request.billing_address or 'N/A'"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Product Lines -->
                <t t-if="service_request.order_line">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Products</h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col">Product</th>
                                            <th scope="col">Description</th>
                                            <th scope="col">Quantity</th>
                                            <th scope="col">Unit Price</th>
                                            <th scope="col">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="service_request.order_line" t-as="line">
                                            <tr>
                                                <td t-esc="line.product_id.name if line.product_id else 'N/A'"/>
                                                <td t-esc="line.name or 'N/A'"/>
                                                <td t-esc="line.product_uom_qty"/>
                                                <td t-esc="'{:.2f}'.format(line.price_unit)"/>
                                                <td t-esc="'{:.2f}'.format(line.price_subtotal)"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="4" class="text-end fw-bold">Total:</td>
                                            <td class="fw-bold" t-esc="'{:.2f}'.format(service_request.amount_total)"/>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>

                <div class="row mt-4">
                    <div class="col">
                        <a href="/my/service_requests" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-2"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Thank You Page -->
    <template id="portal_service_request_thankyou" name="Service Request Thank You">
        <t t-call="portal.portal_layout">
            <t t-set="title">Thank You</t>
            <t t-set="breadcrumb" t-value="[{'title': 'Home', 'url': '/my'}, {'title': 'Service Requests', 'url': '/my/service_requests'}, {'title': 'Thank You', 'url': False}]"/>
            <div class="o_portal_wrap container my-5 text-center">
                <div class="card shadow-sm p-5">
                    <i class="fa fa-check-circle fa-4x text-success mb-3"></i>
                    <h2>Thank you!</h2>
                    <p>Your service request has been submitted successfully.</p>
                    <div class="mt-4">
                        <a href="/my/service_requests" class="btn btn-primary me-2">
                            View My Service Requests
                        </a>
                        <a href="/my" class="btn btn-outline-secondary">
                            Back to My Account
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
