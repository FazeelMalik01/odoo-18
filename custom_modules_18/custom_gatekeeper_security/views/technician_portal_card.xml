<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_technician_task" name="Portal Home - Technician Card" inherit_id="portal.portal_my_home" priority="60">
        <xpath expr="//div[@id='portal_service_category']" position="inside">
            <div class="o_portal_index_card col-md-6 order-2" groups="custom_gatekeeper_security.group_gatekeeper_technician">
                <a t-attf-href="/my/gate_lock_assigned"
                   class="d-flex gap-2 gap-md-3 py-3 pe-md-3 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_index_card_icon">
                        <img src="/custom_gatekeeper_security/static/src/img/service-request.svg" alt="Gate Lock Service Assigned" style="width: 64px; height: 64px;"/>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-normal">Gate Lock Service Assigned</h5>
                        <p class="text-muted mb-0">View and manage your assigned work orders</p>
                    </div>
                </a>
            </div>
        </xpath>
    </template>
</odoo>