<odoo>
    <template id="owner_approval_detail_template" name="Owner Approval Detail">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <strong>Reference</strong>
                                <div t-esc="approval.name"/>
                            </div>
                            <div class="col-md-6">
                                <strong>BOQ Reference</strong>
                                <div t-esc="approval.boq_ref"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Title</strong>
                                <div t-esc="approval.title"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Status</strong>
                                <div>
                                    <span class="badge bg-info" t-esc="approval.state"/>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <strong>Type</strong>
                                <div t-esc="approval.approval_type"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Project</strong>
                                <div t-esc="approval.project_id.name"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Task</strong>
                                <div t-esc="approval.task_id.name"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Responsible</strong>
                                <div t-esc="approval.responsible_user_id.name"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Owner</strong>
                                <div t-esc="approval.owner_partner_id.name"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Submission Date</strong>
                                <div t-esc="approval.submission_date"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Required Response Days</strong>
                                <div t-esc="approval.required_response_days"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Owner Response Date</strong>
                                <div t-esc="approval.owner_response_date"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Due Date</strong>
                                <div t-esc="approval.due_date"/>
                            </div>
                            <div class="col-md-12 mb-3">
                                <strong>Approval Description</strong>
                                <textarea t-esc="approval.location" class="form-control" readonly="1" rows="4"/>
                            </div>
                            <div class="col-md-12">
                                <strong>Attachments</strong>
                                <div class="d-flex justify-content-center align-items-center gap-1">
                                    <div class="border rounded p-2 col-md-10">
                                        <t t-if="approval.attachment_ids">
                                            <ul class="list-unstyled mb-0">
                                                <t t-foreach="approval.attachment_ids" t-as="att">
                                                    <li>
                                                        <a t-att-href="'/web/content/%s?download=true' % att.id" t-att-title="att.name" target="_blank" class="text-decoration-none">
                                                            <t t-esc="att.name"/>
                                                        </a>
                                                    </li>
                                                </t>
                                            </ul>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted">No attachments</span>
                                        </t>
                                    </div>
                                    <t t-set="is_locked" t-value="approval.state in ['approved','rejected','late']"/>
                                    <form t-att-action="'/my/owner-approval/upload/%s' % approval.id" method="post" enctype="multipart/form-data" class="col-md-2">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="file" t-att-disabled="is_locked and 'disabled' or None" t-att-id="'file_upload_input_%s' % approval.id" name="attachment" style="display:none" onchange="this.form.submit()"/>
                                        <button type="button"  t-att-class="'btn w-100 ' + ('btn-secondary disabled' if is_locked else 'btn-primary')" t-att-disabled="is_locked and 'disabled' or None" t-att-onclick="'document.getElementById(\'file_upload_input_%s\').click()' % approval.id">
                                            Upload
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <t t-set="is_locked" t-value="approval.state in ['approved','rejected','late']"/>
                        <form t-att-action="'/my/owner-approval/update/%s' % approval.id" method="post" class="mt-3">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <!-- Owner Decision -->
                            <div class="col-md-12 mb-3">
                                <strong>Owner Decision</strong>
                                <select name="decision" class="form-select" t-att-disabled="is_locked and 'disabled' or None">
                                    <option value="">Select decision</option>
                                    <option value="approved" t-att-selected="approval.decision == 'approved'">Approved</option>
                                    <option value="rejected" t-att-selected="approval.decision == 'rejected'">Rejected</option>
                                    <option value="revise" t-att-selected="approval.decision == 'revise'">Revise</option>
                                </select>
                            </div>
                            <!-- Owner Comments -->
                            <div class="col-md-12 mb-3">
                                <strong>Owner Comments</strong>
                                <textarea name="owner_comments" class="form-control" rows="4" t-att-readonly="is_locked and 'readonly' or None" t-esc="approval.owner_comments or ''"/>
                            </div>
                            <!-- Submit button disappears if locked -->
                            <div class="mt-3 d-flex gap-2" t-if="not is_locked">
                                <button type="submit" class="btn btn-primary">Save Response</button>
                            </div>
                            <!-- Visual message -->
                            <div class="alert alert-success mt-3" t-if="is_locked">
                                Response already submitted.
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card mt-4" id="owner_chat" data-anchor="true">
                <div class="card-header">
                    <h3 class="mb-0">Communication history</h3>
                </div>
                <div class="card-body">
                    <t t-set="object" t-value="approval"/>
                    <t t-call="portal.message_thread"/>
                </div>
            </div>
        </t>
    </template>
</odoo>