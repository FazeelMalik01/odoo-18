<odoo>
    <template id="portal_my_home_inherit_approval" name="Portal My Home - Approval Card" inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[@id='portal_client_category']" position="inside">
            <div class="o_portal_index_card col-md-6 order-2">
                <a t-attf-href="/my/owner-approvals"
                   class="d-flex gap-2 gap-md-3 py-3 pe-md-3 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_index_card_icon">
                        <img src="/custom_owner_approval/static/src/img/approval.png" alt="Approval List" style="width: 64px; height: 64px;"/>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-normal">Owner Approvals</h5>
                        <p class="text-muted mb-0">Access all authorized approval in one place</p>
                    </div>
                </a>
            </div>
        </xpath>
    </template>
</odoo>