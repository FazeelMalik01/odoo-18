<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_request_list" model="ir.ui.view">
        <field name="name">purchase.request.list.portal</field>
        <field name="model">purchase.request</field>
        <field name="inherit_id" ref="purchase_request.view_purchase_request_tree"/>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="create_date" optional="hide"/>
                <field name="create_uid" widget="many2one_avatar_user" optional="hide"/>
                <field name="assigned_to" widget="many2one_avatar_user" optional="hide"/>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form.portal</field>
        <field name="model">purchase.request</field>
        <field name="inherit_id" ref="purchase_request.view_purchase_request_form"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <!-- Hide unused fields -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='picking_type_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <!-- Add new fields in the right column group after description field -->
            <xpath expr="//group[.//field[@name='origin']]//field[@name='description']" position="after">
                <field name="project_id" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="stage_id" domain="[('plan_id.name', '=', 'Stage')]" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="request_type"/>
            </xpath>
            
            <!-- Remove date_required from line list view (it should only be on purchase.request form) -->
            <xpath expr="//field[@name='line_ids']//list//field[@name='date_required']" position="replace"/>
            
            <!-- Add date_required to purchase.request form view under Procurement Group -->
            <xpath expr="//field[@name='group_id']" position="after">
                <field name="date_required" string="Expected Delivery Date" readonly="is_editable == False"/>
            </xpath>
            
            <!-- Ensure portal_product_description is added if needed -->
            <xpath expr="//field[@name='line_ids']//list//field[@name='name']" position="after">
                <field name="portal_product_description" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
