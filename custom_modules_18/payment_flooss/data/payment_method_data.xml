<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Payment Method for Flooss -->
    <record id="payment_method_flooss" model="payment.method">
        <field name="name">Flooss</field>
        <field name="code">flooss</field> <!-- must match your Python provider_code -->
        <field name="active">True</field>
        <field name="image" type="base64" file="addons/payment_custom/static/img/wire_transfer.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">none</field>

    </record>
</odoo>
