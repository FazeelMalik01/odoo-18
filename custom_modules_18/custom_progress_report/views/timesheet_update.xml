<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add "No of Workers" field to timesheet list view -->
        <record id="view_task_form2_timesheet_inherit" model="ir.ui.view">
            <field name="name">project.task.form.timesheet.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='timesheet_ids']/list/field[@name='unit_amount']" position="after">
                    <field name="no_of_workers" string="No of Workers" readonly="readonly_timesheet"/>
                </xpath>
                <xpath expr="//field[@name='timesheet_ids']/form/sheet/group/field[@name='unit_amount']" position="after">
                    <field name="no_of_workers" string="No of Workers" readonly="readonly_timesheet"/>
                </xpath>
            </field>
        </record>
    </data>
    
    <!-- Add "No of Workers" field to portal timesheet table -->
    <template id="portal_timesheet_table_inherit" inherit_id="hr_timesheet.portal_timesheet_table">
        <xpath expr="//thead/tr/th[@name='t_label']" position="before">
            <th class="text-end">No of Workers</th>
        </xpath>
        <xpath expr="//tr[@t-foreach='timesheets']/td[@class='text-end']" position="before">
            <td class="text-end"><t t-esc="timesheet.no_of_workers or 1"/></td>
        </xpath>
    </template>
</odoo>
