<odoo>
    <record id="project_edit_project_inherit_show_all_partners" model="ir.ui.view">
        <field name="name">project.project.form.inherit.show.all.partners</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <field name="user_id" position="attributes">
                <!-- Remove any existing domain -->
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>
    <record id="project_task_form_inherit_show_all_users" model="ir.ui.view">
        <field name="name">project.task.form.inherit.show.all.users</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <field name="user_ids" position="attributes">
                <!-- Remove any existing domain restriction -->
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>
    <record id="project_task_kanban_inherit_show_all_users" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.show.all.users</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <field name="user_ids" position="attributes">
                <!-- Remove the restriction so all users (internal + portal) appear -->
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>
    <record id="project_task_form_inherit_subtasks_user_ids_all" model="ir.ui.view">
        <field name="name">project.task.form.inherit.subtasks.user_ids.all</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <!-- Target user_ids inside the sub_tasks_page -->
            <xpath expr="//page[@name='sub_tasks_page']//field[@name='child_ids']//field[@name='user_ids']" position="attributes">
                <attribute name="domain">[]</attribute>
            </xpath>
        </field>
    </record>
</odoo>