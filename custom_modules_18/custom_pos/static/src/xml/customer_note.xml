      <xpath expr="//div[@class='order-summary d-flex flex-column gap-1 px-3 py-2 border-top fw-bolder lh-sm']" position="before">
          <div t-if="props.customNote"
               class="customer-note p-2 mt-2 rounded text-bg-warning bg-opacity-25"
               style="font-weight: 500; font-size: 14px;">
              <strong>General Note:</strong>
              <t t-foreach="props.customNote.split('\n')" t-as="note" t-key="note_index">
                  <br/>• <t t-esc="note"/>
              </t>
          </div>
      </xpath>

