    <!-- ========================= -->
    <!--   HEADER EXTENSION        -->
    <!-- ========================= -->
    <t t-name="custom_pos.ReceiptHeader"
       t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <!-- Add partner info below the company header -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="after">
            <div class="pos-receipt-center-align" style="margin-bottom: 5px;">
                <t t-if="props.data.partner">
                    <div style="font-size: 16px; font-weight: bold;">
                        <t t-out="props.data.partner.name"/>
                    </div>

<t t-if="props.data.partner.phone">
    <div>Phone: <t t-esc="props.data.partner.phone" /></div>
</t>
<t t-if="props.data.partner.mobile">
    <div>Mobile: <t t-esc="props.data.partner.mobile" /></div>
</t>

                    <t t-if="props.data.partner.contact_address">
                        <div style="font-size: 16px; font-weight: bold;">
                            <span>Address: </span>
                            <span t-esc="props.data.partner.contact_address"/>
                        </div>
                    </t>
                </t>
            </div>
        </xpath>

        <!-- Make the original contact section slightly larger -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="attributes">
            <attribute name="style" add="font-size: 18px" separator=" "/>
        </xpath>
    </t>

