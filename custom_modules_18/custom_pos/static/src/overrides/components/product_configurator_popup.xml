<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Override RadioProductAttribute for RTL/LTR support -->
    <t t-name="custom_pos.RadioProductAttribute" 
       t-inherit="point_of_sale.RadioProductAttribute" 
       t-inherit-mode="extension">
        <!-- Target the span inside label with class form-check-label -->
        <xpath expr="//label[@class='form-check-label']/span" position="attributes">
            <attribute name="t-att-dir">this.getTextDirection ? this.getTextDirection(value.name) : 'auto'</attribute>
            <attribute name="style">unicode-bidi: isolate;</attribute>
        </xpath>
    </t>

    <!-- Override PillsProductAttribute for RTL/LTR support -->
    <t t-name="custom_pos.PillsProductAttribute" 
       t-inherit="point_of_sale.PillsProductAttribute" 
       t-inherit-mode="extension">
        <!-- Target the span inside the div with class attribute-name-cell -->
        <xpath expr="//div[hasclass('attribute-name-cell')]/label/span" position="attributes">
            <attribute name="t-att-dir">this.getTextDirection ? this.getTextDirection(value.name) : 'auto'</attribute>
            <attribute name="style">unicode-bidi: isolate;</attribute>
        </xpath>
    </t>

    <!-- Override MultiProductAttribute for RTL/LTR support AND selection order tracking -->
    <t t-name="custom_pos.MultiProductAttribute" 
       t-inherit="point_of_sale.MultiProductAttribute" 
       t-inherit-mode="extension">
        <!-- Add RTL/LTR to span -->
        <xpath expr="//div/label/span" position="attributes">
            <attribute name="t-att-dir">this.getTextDirection ? this.getTextDirection(value.name) : 'auto'</attribute>
            <attribute name="style">unicode-bidi: isolate;</attribute>
        </xpath>
        <!-- Track selection order on click -->
        <xpath expr="//div/label" position="attributes">
            <attribute name="t-on-click">() => this.trackSelection(value.id)</attribute>
        </xpath>
    </t>

    <!-- Override ProductConfiguratorPopup for RTL/LTR support on attribute names -->
    <t t-name="custom_pos.ProductConfiguratorPopup" 
       t-inherit="point_of_sale.ProductConfiguratorPopup" 
       t-inherit-mode="extension">
        <xpath expr="//div[@class='attribute_name mb-2 fw-bolder']" position="attributes">
            <attribute name="t-att-dir">this.getTextDirection ? this.getTextDirection(attributeLine.attribute_id.name) : 'auto'</attribute>
            <attribute name="style">unicode-bidi: isolate;</attribute>
        </xpath>
    </t>

</templates>
