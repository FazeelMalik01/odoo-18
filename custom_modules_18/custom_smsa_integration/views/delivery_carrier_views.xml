<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit delivery carrier form for SMSA: weight-based rates, hide margin -->
    <record id="view_delivery_carrier_form_smsa" model="ir.ui.view">
        <field name="name">delivery.carrier.form.smsa</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <!-- Hide Fixed Price for SMSA (using weight-based rates instead) -->
            <xpath expr="//field[@name='fixed_price']" position="attributes">
                <attribute name="invisible">delivery_type != 'fixed'</attribute>
            </xpath>
            <!-- SMSA tiered rate: first kg + per additional kg -->
            <xpath expr="//field[@name='fixed_price']" position="before">
                <field name="smsa_rate_first_order" widget="monetary" class="oe_inline"
                       invisible="delivery_type != 'smsa'"/>
                <field name="smsa_rate_other_orders" widget="monetary" class="oe_inline"
                       invisible="delivery_type != 'smsa'"/>
            </xpath>
            <!-- Hide Margin on Rate for SMSA -->
            <xpath expr="//field[@name='margin']" position="attributes">
                <attribute name="invisible">delivery_type in ('fixed', 'smsa')</attribute>
            </xpath>
            <!-- Hide Additional margin for SMSA -->
            <xpath expr="//field[@name='fixed_margin']" position="attributes">
                <attribute name="invisible">delivery_type in ('fixed', 'smsa')</attribute>
            </xpath>
        </field>
    </record>
</odoo>
