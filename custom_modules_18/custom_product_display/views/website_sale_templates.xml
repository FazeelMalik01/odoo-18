<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Override filmstrip_categories template to hide subcategories without stock -->
        <template id="filter_filmstrip_categories" inherit_id="website_sale.filmstrip_categories" name="Filter Subcategories by Stock">
            <!-- Filter first entries assignment when category.id exists -->
            <xpath expr="//t[@t-if='category.id']/t[@t-set='entries']" position="replace">
                <t t-set="child_categories" t-value="not search and category.child_id or category.child_id.filtered(lambda c: category.id in search_categories_ids)"/>
                <t t-set="entries" t-value="child_categories.filtered(lambda c: c.has_stocked_products)"/>
            </xpath>
            
            <!-- Filter second entries assignment inside t-if="not entries" -->
            <xpath expr="//t[@t-if='not entries']/t[@t-set='entries']" position="replace">
                <t t-set="parent_child_categories" t-value="not search and parent.child_id or parent.child_id.filtered(lambda c: parent.id in search_categories_ids)"/>
                <t t-set="entries" t-value="parent_child_categories.filtered(lambda c: c.has_stocked_products)"/>
            </xpath>
            
            <!-- Filter entries assignment in else branch -->
            <xpath expr="//t[@t-else='']/t[@t-set='entries']" position="replace">
                <t t-set="entries" t-value="categories.filtered(lambda c: c.has_stocked_products)"/>
            </xpath>
        </template>

        <!-- Override categories_recursive template to hide subcategories without stock in sidebar -->
        <template id="filter_categories_recursive" inherit_id="website_sale.categories_recursive" name="Filter Subcategories in Sidebar by Stock">
            <xpath expr="//ul[@class='nav flex-column nav-hierarchy mt-1 ps-3']/t[@t-foreach='c.child_id']" position="replace">
                <t t-set="filtered_children" t-value="c.child_id.filtered(lambda cat: cat.has_stocked_products)"/>
                <t t-foreach="filtered_children" t-as="c">
                    <t t-if="not search or c.id in search_categories_ids">
                        <t t-call="website_sale.categories_recursive" />
                    </t>
                </t>
            </xpath>
        </template>
    </data>
</odoo>
