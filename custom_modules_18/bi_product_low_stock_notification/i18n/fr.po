"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"            <p>Liste des produits dont la quantité prévue est inférieure à la quantité globale <t t-out=\"object.env.company.min_quantity\"> sont:</t></p><br/>\n"
"        </t>\n"
"        \n"
"        <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr> \n"
"            <th>Nom du produit</th>\n"
"            <th>Quantité de produit</th>\n"
"            <th>Quantité requise</th>\n"
"          </tr>\n"
"        \n"
"        <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"             \n"
"          \n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"object.env.company.min_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'fore_product'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>Liste des produits dont la quantité disponible est inférieure à la quantité minimale individuelle :</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>Liste des produits dont la quantité prévue est inférieure à la quantité minimale individuelle :</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>Nom du produit</th>\n"
"            <th>Individual Minimum Quantity</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>Quantité de produit</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>Quantité prévue du produit</th>\n"
"            </t>\n"
"            <th>Quantité requise</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'reorder'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>Liste des produits dont la quantité disponible est inférieure à la quantité minimale individuelle spécifiée dans les règles de réapprovisionnement :</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>Liste des produits dont la quantité prévue est inférieure à la quantité minimale individuelle selon les règles de réapprovisionnement spécifiées :</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>Nom du produit</th>\n"
"            <th>Stock en quantité minimale</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>Quantité de produit</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>Quantité prévue du produit</th>\n"
"            </t>\n"
"            <th>Quantité requise</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"      \n"
"\t  "

