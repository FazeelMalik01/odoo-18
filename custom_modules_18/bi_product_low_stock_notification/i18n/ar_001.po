#. module: bi_product_low_stock_notification
#: model:mail.template,body_html:bi_product_low_stock_notification.low_stock_email_template
msgid ""
"<p>Hello,</p> <br/><br/>\n"
"        <br/>\n"
"      <t t-if=\"object.env.company.notification_products == 'for_all'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"            <p>List of product which have less on hand quantity  then global quantity <t t-out=\"object.env.company.min_quantity\"> are:</t></p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"            <p>List of product which have less forecast quantity then global quantity <t t-out=\"object.env.company.min_quantity\"> are:</t></p><br/>\n"
"        </t>\n"
"        \n"
"        <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr> \n"
"            <th>Product Name</th>\n"
"            <th>Product Quantity</th>\n"
"            <th>Required Quantity</th>\n"
"          </tr>\n"
"        \n"
"        <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"             \n"
"          \n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"object.env.company.min_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'fore_product'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>List of product which have less on hand quantity  then individual minimum quantity are:</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>List of product which have less forecast quantity  then individual minimum quantity are:</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>Product Name</th>\n"
"            <th>Individual Minimum Quantity</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>Product Quantity</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>Product Forecast Quantity</th>\n"
"            </t>\n"
"            <th>Required Quantity</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'reorder'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>List of product which have less on hand quantity  then individual minimum quantity on reorder rules specified are:</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>List of product which have less forecast quantity  then individual minimum quantity on reorder rules specified are:</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>Product Name</th>\n"
"            <th>Minimum Quantity Stock</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>Product Quantity</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>Product Forecast Quantity</th>\n"
"            </t>\n"
"            <th>Required Quantity</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"      \n"
"\t  "
msgstr ""
"<p>مرحبًا,</p> <br/><br/>\n"
"        <br/>\n"
"      <t t-if=\"object.env.company.notification_products == 'for_all'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"            <p>قائمة المنتجات التي لديها كمية أقل في متناول اليد من الكمية العالمية <t t-out=\"object.env.company.min_quantity\"> نكون:</t></p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"            <p>قائمة المنتجات التي لها كمية متوقعة أقل من الكمية العالمية <t t-out=\"object.env.company.min_quantity\"> نكون:</t></p><br/>\n"
"        </t>\n"
"        \n"
"        <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr> \n"
"            <th>اسم المنتج</th>\n"
"            <th>كمية المنتج</th>\n"
"            <th>الكمية المطلوبة</th>\n"
"          </tr>\n"
"        \n"
"        <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"             \n"
"          \n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"object.env.company.min_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'fore_product'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>قائمة المنتجات التي تحتوي على كمية أقل في متناول اليد من الكمية الدنيا الفردية هي:</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>قائمة المنتجات التي لها كمية متوقعة أقل من الكمية الدنيا الفردية هي:</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>اسم المنتج</th>\n"
"            <th>الحد الأدنى للكمية الفردية</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>كمية المنتج</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>كمية المنتج المتوقعة</th>\n"
"            </t>\n"
"            <th>الكمية المطلوبة</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"\n"
"      <t t-if=\"object.env.company.notification_products == 'reorder'\">\n"
"        <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"           <p>قائمة المنتجات التي تحتوي على كمية أقل في متناول اليد من الكمية الدنيا الفردية وفقًا لقواعد إعادة الطلب المحددة:</p><br/>\n"
"        </t>\n"
"        <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"           <p>قائمة المنتجات التي لها كمية متوقعة أقل من الكمية الدنيا الفردية وفقًا لقواعد إعادة الطلب المحددة هي:</p><br/>\n"
"        </t>\n"
"         <table class=\"table table-bordered\" style=\"width: 50%; border: 2px solid black;\">\n"
"          <tr>\n"
"            <th>اسم المنتج</th>\n"
"            <th>الحد الأدنى لكمية المخزون</th>\n"
"            <t t-if=\"object.env.company.notification_base == 'on_hand'\">\n"
"              <th>كمية المنتج</th>\n"
"            </t>\n"
"            <t t-if=\"object.env.company.notification_base == 'fore_cast'\">\n"
"              <th>كمية المنتج المتوقعة</th>\n"
"            </t>\n"
"            <th>الكمية المطلوبة</th>\n"
"          </tr>\n"
"           <t t-foreach=\"object.env.company.low_stock_products_ids\" t-as=\"product\">\n"
"          <tr>\n"
"          <td><t t-out=\"product.name\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity\"/></td>\n"
"          <td><t t-out=\"product.stock_quantity\"/></td>\n"
"          <td><t t-out=\"product.limit_quantity - product.stock_quantity\"/></td>\n"
"        </tr>\n"
"        </t>\n"
"      </table>\n"
"      </t>\n"
"      \n"
"\t  "

