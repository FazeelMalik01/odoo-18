<odoo>
    <!-- Epson Invoice Template -->
    <template id="peptidat_invoice_report">
        <t t-set="hide_header" t-value="True"/>
        <t t-foreach="docs" t-as="o">
            <main>
                <t t-call="account.report_invoice_document" />
            </main>
        </t>
    </template>
    <!-- Paperformat -->
    <record id="paperformat_peptidat_invoice" model="report.paperformat">
        <field name="name">Peptidat Invoice Format</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">200</field>
        <field name="page_width">210</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>
</odoo>