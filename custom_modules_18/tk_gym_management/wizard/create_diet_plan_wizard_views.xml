<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="create_diet_plan_wizard_view_form" model="ir.ui.view">
        <field name="name">create_diet_plan_wizard_view_form</field>
        <field name="model">create.diet.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Diet Plan.." required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="member_id" domain="[('is_member', '=', True)]"
                                   options="{'no_create': True, 'no_create_edit':True}" required="1"/>
                            <field name="diet_category_id" required="1" options="{'no_create': True}"/>
                            <field name="diet_type_id" required="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="dietitian_id" required="1" options="{'no_create': True}"/>
                            <field name="date" required="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Create Plan" type="object" name="create_plan" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="create_diet_plan_action" model="ir.actions.act_window">
        <field name="name">Create Diet PLan</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">create.diet.plan</field>
        <field name="view_id" ref="create_diet_plan_wizard_view_form"/>
        <field name="view_mode">list,form</field>
        <field name="target">new</field>
    </record>
</odoo>
