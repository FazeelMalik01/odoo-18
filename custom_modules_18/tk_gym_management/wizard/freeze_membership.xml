<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="freeze_membership_wizard_view" model="ir.ui.view">
        <field name="name">freeze.membership.wizard.form</field>
        <field name="model">freeze.membership.wizard</field>
        <field name="arch" type="xml">
            <form string="Freeze Membership">
                <group>
                    <field name="membership_id" invisible="1"/>
                    <field name="duration_days" required="1"/>
                    <field name="extra_charges"/>
                </group>
                <footer>
                    <button string="Confirm"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            name="action_cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="freeze_membership_wizard_action" model="ir.actions.act_window">
        <field name="name">Freeze Membership</field>
        <field name="res_model">freeze.membership.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>