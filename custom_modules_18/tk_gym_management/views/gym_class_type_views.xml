<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="gym_class_type_view_form" model="ir.ui.view">
            <field name="name">gym.class.type.view.form</field>
            <field name="model">gym.class.types</field>
            <field name="arch" type="xml">
                <form string="gym_class_type_form">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" options="{'line_breaks': False}" widget="text"
                                       placeholder="e.g. Zumba" required="1"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="gym_class_type_view_tree" model="ir.ui.view">
            <field name="name">gym.class.type.view.tree</field>
            <field name="model">gym.class.types</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record id="gym_class_types_action" model="ir.actions.act_window">
            <field name="name">Gym Class Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">gym.class.types</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
