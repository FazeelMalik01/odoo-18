<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="meal_type_tree_view" model="ir.ui.view">
        <field name="name">meal.type.tree.view</field>
        <field name="model">meal.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="meal_type"/>
                <field name="food_item_id" required="1"/>
                <field name="calories"/>
                <field name="food_unit_id"/>
                <field name="meal_time" required="1"/>
                <field name="qty"/>
                <field name="intake_unit_id"/>
                <field name="unit" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="meal_type_action" model="ir.actions.act_window">
        <field name="name">Meal Types</field>
        <field name="res_model">meal.type</field>
        <field name="view_mode">list</field>
    </record>
</odoo>