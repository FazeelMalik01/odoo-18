<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="diet_plan_template_form_view" model="ir.ui.view">
        <field name="name">diet.plan.template.form.view</field>
        <field name="model">diet.plan.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Diet Template Name.." required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="diet_category_id" options="{'no_create':True}"/>
                            <field name="diet_type_id" options="{'no_create':True}"/>
                        </group>
                        <group>
                            <field name="charges"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="diet_meals" string="Diet Meals">
                            <field name="diet_meal_template_ids">
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="day"/>
                                            </group>
                                            <group>
                                                <field name="total_calories"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Breakfast">
                                                <field name="breakfast_ids"
                                                       context="{'default_meal_type': 'breakfast'}">
                                                    <list editable="bottom">
                                                        <field name="meal_type" column_invisible="1"/>
                                                        <field name="food_item_id" options="{'no_create':True}"/>
                                                        <field name="calories" string="Calories per Unit"/>
                                                        <field name="food_unit_id" options="{'no_open':True}"/>
                                                        <field name="meal_time" widget="float_time"/>
                                                        <field name="qty"/>
                                                        <field name="intake_unit_id" options="{'no_open':True}"/>
                                                        <field name="total_calories" readonly="1"/>
                                                        <field name="unit" column_invisible="1"/>
                                                    </list>
                                                </field>
                                                <group class="oe_subtotal_footer">
                                                    <field name="breakfast_calories" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Morning Snack">
                                                <field name="morning_snack_ids"
                                                       context="{'default_meal_type': 'midmorningsnacks'}">
                                                    <list editable="bottom">
                                                        <field name="meal_type" column_invisible="1"/>
                                                        <field name="food_item_id" options="{'no_create':True}"/>
                                                        <field name="calories" string="Calories per Unit"/>
                                                        <field name="food_unit_id" options="{'no_open':True}"/>
                                                        <field name="meal_time" widget="float_time"/>
                                                        <field name="qty"/>
                                                        <field name="intake_unit_id" options="{'no_open':True}"/>
                                                        <field name="total_calories" readonly="1"/>
                                                        <field name="unit" column_invisible="1"/>
                                                    </list>
                                                </field>

                                                <group class="oe_subtotal_footer">
                                                    <field name="morning_snack_calories" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Lunch">
                                                <field name="lunch_ids" context="{'default_meal_type': 'lunch'}">
                                                    <list editable="bottom">
                                                        <field name="meal_type" column_invisible="1"/>
                                                        <field name="food_item_id" options="{'no_create':True}"/>
                                                        <field name="calories" string="Calories per Unit"/>
                                                        <field name="food_unit_id" options="{'no_open':True}"/>
                                                        <field name="meal_time" widget="float_time"/>
                                                        <field name="qty"/>
                                                        <field name="intake_unit_id" options="{'no_open':True}"/>
                                                        <field name="total_calories" readonly="1"/>
                                                        <field name="unit" column_invisible="1"/>
                                                    </list>
                                                </field>

                                                <group class="oe_subtotal_footer">
                                                    <field name="lunch_calories" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Evening Snack">
                                                <field name="evening_snack_ids"
                                                       context="{'default_meal_type': 'evening-snacks'}">
                                                    <list editable="bottom">
                                                        <field name="meal_type" column_invisible="1"/>
                                                        <field name="food_item_id" options="{'no_create':True}"/>
                                                        <field name="calories" string="Calories per Unit"/>
                                                        <field name="food_unit_id" options="{'no_open':True}"/>
                                                        <field name="meal_time" widget="float_time"/>
                                                        <field name="qty"/>
                                                        <field name="intake_unit_id" options="{'no_open':True}"/>
                                                        <field name="total_calories" readonly="1"/>
                                                        <field name="unit" column_invisible="1"/>
                                                    </list>
                                                </field>

                                                <group class="oe_subtotal_footer">
                                                    <field name="evening_snack_calories" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Dinner">
                                                <field name="dinner_ids" context="{'default_meal_type': 'dinner'}">
                                                    <list editable="bottom">
                                                        <field name="meal_type" column_invisible="1"/>
                                                        <field name="food_item_id" options="{'no_create':True}"/>
                                                        <field name="calories" string="Calories per Unit"/>
                                                        <field name="food_unit_id" options="{'no_open':True}"/>
                                                        <field name="meal_time" widget="float_time"/>
                                                        <field name="qty"/>
                                                        <field name="intake_unit_id" options="{'no_open':True}"/>
                                                        <field name="total_calories" readonly="1"/>
                                                        <field name="unit" column_invisible="1"/>
                                                    </list>
                                                </field>

                                                <group class="oe_subtotal_footer">
                                                    <field name="dinner_calories" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Nutrients">
                                                <field name="diet_nutrient_ids">
                                                    <list editable="bottom">
                                                        <field name="nutrient_id" options="{'no_create':True}"/>
                                                        <field name="value"/>
                                                        <field name="unit"/>
                                                    </list>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_calories" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="diet_plan_template_tree_view" model="ir.ui.view">
        <field name="name">diet.plan.template.tree.view</field>
        <field name="model">diet.plan.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="diet_category_id"/>
                <field name="diet_type_id"/>
                <field name="total_calories"/>
                <field name="charges"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="diet_meal_template_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>
    <record id="diet_plan_template_action" model="ir.actions.act_window">
        <field name="name">Diet Plan Templates</field>
        <field name="res_model">diet.plan.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>