<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--member.attendance.lines form view-->
    <record id="member_attendance_lines_form_view" model="ir.ui.view">
        <field name="name">member.attendance.lines.form.view</field>
        <field name="model">member.attendance.lines</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <header>
                    <button name="check_in_member" type="object" string="Check In"
                            invisible="state != 'new'" class="btn-primary" icon="fa-sign-in"/>
                    <button name="check_out_datetime_member" type="object" string="Check Out"
                            invisible="state != 'checked_in'" class="btn-primary" icon="fa-sign-out"/>
                </header>
                <sheet>
                    <group string="Attendance Details">
                        <group>
                            <field name="check_in"/>
                            <field name="check_out"/>
                        </group>
                        <group>
                            <field name="hours"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--member attendance form view-->
    <record id="member_attendance_form_view" model="ir.ui.view">
        <field name="name">member.attendance.form.view</field>
        <field name="model">member.attendance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Check Out" name="check_out_member" type="object" class="oe_highlight"
                            invisible="1"/>
                </header>
                <sheet>
                    <div class="row">
                        <div class="col-6">
                            <div class="oe_title">
                                <label for="member_id"/>
                                <h1>
                                    <field name="member_id" required="1" options="{'no_create':True}"/>
                                </h1>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <button type="object" string="" name="action_pass"
                                    class="btn btn-outline-primary mx-1 position-relative">
                                Total Hours -
                                <field name="total_hours"/>
                            </button>
                            <button type="object" string=" " name="action_pass"
                                    invisible="attended_hours &lt; total_hours"
                                    class="btn btn-outline-success mx-1 position-relative">
                                Attended Hours -
                                <field name="attended_hours"/>
                            </button>
                            <button type="object" string=" " name="action_pass"
                                    invisible="attended_hours &gt;= total_hours"
                                    class="btn btn-outline-danger mx-1 position-relative">
                                Attended Hours -
                                <field name="attended_hours"/>
                            </button>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="gym_hours_per_day"/>
                            <field name="check_in" invisible="1"/>
                        </group>
                        <group>
                            <field name="check_out" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attendance">
                            <field name="member_attendance_line_ids">
                                <list editable="bottom">
                                    <field name="check_in" readonly="1" force_save="1"
                                           decoration-warning="state == 'checked_in'"
                                           decoration-success="complete_hours"
                                           decoration-danger="incomplete_hours"/>
                                    <field name="check_out" decoration-warning="state == 'checked_in'"
                                           decoration-success="complete_hours"
                                           readonly="1"
                                           decoration-danger="incomplete_hours"/>
                                    <field name="hours" decoration-warning="state == 'checked_in'"
                                           decoration-success="complete_hours"
                                           decoration-danger="incomplete_hours" readonly="1"/>
                                    <field name="state" widget="badge" decoration-warning="state == 'checked_in'"
                                           decoration-success="complete_hours"
                                           decoration-danger="incomplete_hours"/>
                                    <field name="complete_hours" column_invisible="True"/>
                                    <field name="incomplete_hours" column_invisible="True"/>
                                    <button name="check_in_member" type="object" string="Check In"
                                            invisible="state != 'new'"
                                            class="btn-primary" icon="fa-sign-in"/>
                                    <button name="check_out_datetime_member" type="object" string="Check Out"
                                            invisible="state != 'checked_in'" class="btn-primary" icon="fa-sign-out"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="member_attendance_tree_view" model="ir.ui.view">
        <field name="name">member.attendance.tree.view</field>
        <field name="model">member.attendance</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_id"/>
                <field name="gym_hours_per_day"/>
                <field name="check_in" column_invisible="True"/>
                <field name="check_out" column_invisible="True"/>
            </list>
        </field>
    </record>
    <record id="member_attendance_search_view" model="ir.ui.view">
        <field name="name">member.attendance.search.view</field>
        <field name="model">member.attendance</field>
        <field name="arch" type="xml">
            <search>
                <field name="member_id"/>
                <group string="Group By">
                    <filter name="member_id" string="Gym Members"
                            context="{'group_by': 'member_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="member_attendance_action" model="ir.actions.act_window">
        <field name="name">Members Attendance</field>
        <field name="res_model">member.attendance</field>
        <field name="view_mode">list,form,search</field>
    </record>
</odoo>