<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="diet_category_view_form" model="ir.ui.view">
        <field name="name">diet_category_view_form</field>
        <field name="model">diet.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" placeholder="e.g. Alkaline diet" required="1" />
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="diet_category_view_tree" model="ir.ui.view">
        <field name="name">diet_category_view_tree</field>
        <field name="model">diet.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
            </list>
        </field>
    </record>
    <record id="diet_category_action" model="ir.actions.act_window">
        <field name="name">Diet Categories</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">diet.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>