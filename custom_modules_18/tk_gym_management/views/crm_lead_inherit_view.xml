<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <!-- Inherit Form View to Modify it -->
    <record id="crm_lead_inherit_form_view" model="ir.ui.view">
        <field name="name">crm.lead.inherit.form.view</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='extra']" position="before">
                <!-- Add your fields or attributes here -->
                <page name="diet_details" string="Diet Details">
                    <group string="General Details">
                        <group>
                            <field name="birthdate"/>
                        </group>
                        <group>
                            <field name="gender" widget='radio' options="{'horizontal': 1}"/>
                        </group>
                    </group>
                    <group string="Diet Details">
                        <group>
                            <field name="diet_category_id" options="{'no_create':True}"/>
                        </group>
                        <group>
                            <field name="diet_type_id" options="{'no_create':True}"/>
                        </group>
                    </group>
                    <group>
                        <field name="goals_details"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="after">
                <button name="%(create_diet_plan_action)d" type="action" string="Create Diet Plan"
                        invisible="type == 'lead' or is_won" class="btn-primary"/>
                <field name="is_form_website" invisible="1"/>
                <field name="is_won" invisible="1"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_diet_plan"
                        icon="fa-calendar" invisible="not diet_plan_id" string="Diet Plan">
                    <field name="diet_plan_id" string="Diet Plan" widget="statinfo" invisible="1"/>
                </button>
            </xpath>

        </field>
    </record>

 
    <record model="ir.actions.act_window" id="crm_lead_all_opportunities">
        <field name="name">Opportunities</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,kanban,graph,pivot,calendar,form,activity</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="context">{
            'default_type':'opportunity',
            'search_default_type': 'opportunity',
            "search_default_from_website":1
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Lead
            </p>
            <p>
                Leads are the qualification step before the creation of an opportunity.
            </p>
        </field>
    </record>

    <record id="crm.crm_lead_all_leads" model="ir.actions.act_window">
        <field name="context">
            {
            'default_type':'lead',
            'search_default_type': 'lead',
            'search_default_to_process':1,
            "search_default_from_website":1
            }
        </field>
    </record>

    <record id="crm_lead_search_inherit" model="ir.ui.view">
        <field name="name">crm.lead.inherit.search</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <filter string="From Website" name="from_website" domain="[('is_form_website', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="crm_opportunity_search_inherit" model="ir.ui.view">
        <field name="name">crm.opportunity.inherit.search</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_lost']" position="after">
                <filter string="From Website" name="from_website" domain="[('is_form_website', '=', True)]"/>
            </xpath>
        </field>
    </record>
</odoo>
