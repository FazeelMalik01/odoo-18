<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="gym_exercise_for_tree_view" model="ir.ui.view">
        <field name="name">gym.exercise.for.tree.view</field>
        <field name="model">exercise.for</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" required="1"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>
    <record id="gym_exercise_for_action" model="ir.actions.act_window">
        <field name="name">Gym Exercises</field>
        <field name="res_model">exercise.for</field>
        <field name="view_mode">list</field>
    </record>
</odoo>