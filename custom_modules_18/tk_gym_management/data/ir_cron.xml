<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="validate_membership_date_based" model="ir.cron">
            <field name="name">Gym Management: Validate Membership Status based on End date</field>
            <field name="model_id" ref="tk_gym_management.model_memberships_member"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.expire_membership_after_end_date()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
        <record id="membership_renewal_reminder" model="ir.cron">
            <field name="name">Gym Management: Membership Renewal Reminder According to Reminder Days</field>
            <field name="model_id" ref="tk_gym_management.model_memberships_member"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.send_reminder_membership_renewal()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
