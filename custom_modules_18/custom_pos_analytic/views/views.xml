<odoo>
  <data>
    <!-- Extend POS Configuration View -->
    <record id="pos_config_view_form_inherit" model="ir.ui.view">
      <field name="name">pos.config.view.form.inherit.pos.receipt.type</field>
      <field name="model">pos.config</field>
      <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//setting[@id='other_devices']" position="before">
          <setting string="Analytic Account" help="Select the analytic account for this POS configuration.">
            <field name="analytic_account_id"/>
          </setting>
        </xpath>
      </field>
    </record>
    <record id="view_pos_order_form_inherit_analytic_account" model="ir.ui.view">
      <field name="name">pos.order.form.inherit.analytic.account</field>
      <field name="model">pos.order</field>
      <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='extra']//group[@name='other_information']" position="inside">
          <field name="analytic_account_id" readonly='1'/>
        </xpath>
      </field>
    </record>
    <record id="view_pos_session_form_inherit_analytic" model="ir.ui.view">
      <field name="name">pos.session.form.view.analytic.inherit</field>
      <field name="model">pos.session</field>
      <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
      <field name="arch" type="xml">
        <!-- Insert after the cash_register_balance_end_real field -->
        <xpath expr="//field[@name='cash_register_balance_end_real']" position="after">
          <field name="analytic_account_id" string="Analytic Account"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>