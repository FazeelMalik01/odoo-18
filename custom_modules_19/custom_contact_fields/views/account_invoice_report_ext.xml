<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Show PO Number on customer invoice PDF -->
    <template id="report_invoice_document_inherit_po_number_custom" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="inside">
            <div class="col" t-if="o.po_number" name="po_number">
                <strong>PO Number</strong>
                <div t-field="o.po_number"/>
            </div>
        </xpath>
    </template>

    <record id="view_move_form_inherit_po_number_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.po.number.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add PO Number after Invoice Date in the invoice header right column -->
            <xpath expr="//group[@id='header_left_group']/following-sibling::group[1]//field[@name='invoice_date']" position="after">
                <field name="po_number" string="PO Number"/>
            </xpath>

        </field>
    </record>

    <record id="view_move_form_inherit_order_id_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.order.id.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Add Order ID text field just after PO Number (which is after Invoice Date) -->
            <xpath expr="//group[@id='header_left_group']/following-sibling::group[1]//field[@name='po_number']" position="after">
                <field name="order_id" string="Order ID"/>
            </xpath>

        </field>
    </record>

</odoo>

