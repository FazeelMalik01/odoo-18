<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend SO form: add PO Number after payment_term_id -->
    <record id="view_order_form_inherit_po_number_custom" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.po.number.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="po_number" placeholder="Customer PO Number"/>
            </xpath>

             <!-- SO line list: show editable per-line warehouse selector (uses per-line warehouse_id field) -->
             <!-- In sale.view_order_form, the inline grid is a <list> and the taxes field is 'tax_ids' -->
             <xpath expr="//field[@name='order_line']/list//field[@name='tax_ids']"
                    position="after">
                 <field name="warehouse_id"
                        widget="many2one"
                        options="{'no_create': True, 'no_open': True}"
                        optional="show"/>
            </xpath>

             <!-- SO line form: show per-line warehouse selector -->
             <xpath expr="//field[@name='order_line']/form//field[@name='tax_ids']"
                    position="after">
                 <field name="warehouse_id"
                        widget="many2one"
                        options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

</odoo>

