<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_inherit_line_warehouse" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.line.warehouse</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- PO line list view -->
            <xpath expr="//field[@name='order_line']/list//field[@name='product_id']" position="after">
                <field name="dropshipping" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='tax_ids']" position="after">
                <field name="warehouse_id"
                       widget="many2one"
                       options="{'no_create': True, 'no_open': True}"
                       optional="show"
                       invisible="dropshipping"/>
                <field name="dropship_customer_id"
                       optional="show"
                       invisible="not dropshipping"/>
            </xpath>

            <!-- PO line form -->
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="after">
                <field name="dropshipping"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='tax_ids']" position="after">
                <field name="warehouse_id"
                       widget="many2one"
                       options="{'no_create': True}"
                       invisible="dropshipping"/>
                <field name="dropship_customer_id"
                       invisible="not dropshipping"/>
            </xpath>

            <!-- Smart button for Dropship Sale Order -->
            <xpath expr="//sheet/div[@name='button_box']" position="inside">
                <button name="action_view_dropship_sale_order"
                        type="object"
                        class="oe_stat_button"
                        invisible="not dropship_sale_order_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Sale Order</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>

    <!-- Rename 'Untaxed Amount' label to 'Subtotal' on PO tree views -->
    <record id="purchase_order_tree_inherit_subtotal_label" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit.subtotal.label</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_untaxed']" position="attributes">
                <attribute name="string">Subtotal</attribute>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_kpis_tree_inherit_subtotal_label" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.inherit.subtotal.label</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_untaxed']" position="attributes">
                <attribute name="string">Subtotal</attribute>
            </xpath>
        </field>
    </record>

</odoo>