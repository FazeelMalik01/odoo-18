<odoo>
    <record id="view_crm_lead_form_inherit_field_service" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.field.service</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="gps" invisible="hide_service_fields"/>
                <field name="fiver" invisible="hide_service_fields"/>
                <field name="poles" invisible="hide_service_fields"/>
            </xpath>
        </field>
    </record>
</odoo>
