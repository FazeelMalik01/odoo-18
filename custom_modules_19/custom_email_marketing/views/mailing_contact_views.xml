<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit list view — anchor after a known field -->
    <record id="view_mailing_contact_list_company" model="ir.ui.view">
        <field name="name">mailing.contact.list.company.inherit</field>
        <field name="model">mailing.contact</field>
        <field name="inherit_id" ref="mass_mailing.mailing_contact_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="company_id" optional="show" groups="base.group_multi_company" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit the form view to add company_id -->
    <record id="view_mailing_contact_form_company" model="ir.ui.view">
        <field name="name">mailing.contact.form.company.inherit</field>
        <field name="model">mailing.contact</field>
        <field name="inherit_id" ref="mass_mailing.mailing_contact_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="company_id" groups="base.group_multi_company" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- New action filtered by allowed companies -->
    <record id="action_view_mass_mailing_contacts_company" model="ir.actions.act_window">
        <field name="name">Mailing List Contacts</field>
        <field name="res_model">mailing.contact</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{
            'default_company_id': allowed_company_ids[0]
        }</field>
    </record>

    <!-- Hide the original contacts menu item -->
    <record id="mass_mailing.menu_email_mass_mailing_contacts" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Add replacement menu item -->
    <menuitem id="menu_email_mass_mailing_contacts_company"
              name="Mailing List Contacts"
              parent="mass_mailing.mass_mailing_mailing_list_menu"
              sequence="2"
              action="action_view_mass_mailing_contacts_company"/>

</odoo>