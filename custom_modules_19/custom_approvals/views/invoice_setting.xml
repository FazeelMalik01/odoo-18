<odoo>
    <record id="res_config_settings_view_form_account_custom" model="ir.ui.view">
        <field name="name">res.config.settings.account.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add new block AFTER connectors -->
            <xpath expr="//block[@name='fiscal_localization_setting_container']" position="after">
                <block title="Invoice Approval Settings" id="invoice_approval_settings_block">
                    <setting id="accounts_finance_manager" string="Accounts Finance Manager">
                        <field name="invoice_fm"/>
                    </setting>
                    <setting id="accounts_ceo" string="Accounts CEO">
                        <field name="invoice_ceo"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>