
<odoo>
    <record id="res_config_settings_view_form_timesheet_custom" model="ir.ui.view">
        <field name="name">res.config.settings.timesheet.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_timesheet.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add new block AFTER connectors -->
            <xpath expr="//block[@name='time_encoding_setting_container']" position="after">
                <block title="Timesheet Approval Settings" id="timesheet_approval_settings_block">
                    <setting id="timesheet_amount_setting" string="Timesheet Manager">
                        <field name="timesheet_manager"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>