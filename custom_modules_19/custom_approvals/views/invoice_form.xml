<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_custom_approvals" model="ir.ui.view">
        <field name="name">account.move.form.custom_approvals</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- ① Add approval_state to the status-bar (after built-in state widget) -->
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="after">
                <field
                    name="approval_state"
                    widget="statusbar"
                    statusbar_visible="pending_fm,pending_ceo,approved"
                    invisible="move_type == 'entry' or not approval_state"
                />
            </xpath>

            <!-- ② Inject invisible helper fields needed for button conditions -->
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="before">
                <field name="show_fm_approve"  invisible="1"/>
                <field name="show_ceo_buttons" invisible="1"/>
            </xpath>

            <xpath
                expr="//button[@name='action_post'][2]"
                position="after">

                <!-- Finance Manager: Approve button -->
                <button
                    name="action_fm_approve"
                    string="Approve (FM)"
                    class="oe_highlight"
                    type="object"
                    invisible="not show_fm_approve"
                />

                <!-- CEO: Confirm / Refuse buttons -->
                <button
                    name="action_ceo_approve"
                    string="Confirm"
                    class="oe_highlight"
                    type="object"
                    invisible="not show_ceo_buttons"
                />
                <button
                    name="action_ceo_refuse"
                    string="Refuse"
                    class="btn-danger"
                    type="object"
                    invisible="not show_ceo_buttons"
                    confirm="Are you sure you want to refuse this invoice?"
                />
            </xpath>

            <xpath
                expr="//button[@name='action_post'][1]"
                position="attributes">
                <attribute name="invisible">hide_post_button or move_type != 'entry' or approval_state != 'approved'</attribute>
            </xpath>

            <xpath
                expr="//button[@name='action_post'][2]"
                position="attributes">
                <attribute name="invisible">hide_post_button or move_type == 'entry' or display_inactive_currency_warning or approval_state != 'approved'</attribute>
            </xpath>

        </field>
    </record>

</odoo>