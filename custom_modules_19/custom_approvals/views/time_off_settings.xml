<odoo>
    <record id="res_config_settings_view_form_hr_custom" model="ir.ui.view">
        <field name="name">res.config.settings.hr.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add new block AFTER connectors -->
            <xpath expr="//block[@name='employees_setting_container']" position="after">
                <block title="HR Approval Settings" id="hr_approval_settings_block">
                    <setting id="hr_setting" string="HR Manager">
                        <field name="hr"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>