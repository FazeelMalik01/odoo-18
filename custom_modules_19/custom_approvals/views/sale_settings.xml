<odoo>
    <record id="res_config_settings_view_form_inherit_custom" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Add new block AFTER connectors -->
            <xpath expr="//block[@id='connectors_setting_container']" position="after">

                <block title="Approval Settings" id="approval_settings_block">

                    <setting id="discount_setting" string="Discount Limit">
                        <field name="discount"/>
                    </setting>

                    <setting id="pm_setting" string="Project Manager">
                        <field name="pm"/>
                    </setting>

                    <setting id="fm_setting" string="Finance Manager">
                        <field name="fm"/>
                    </setting>

                    <setting id="ceo_setting" string="CEO">
                        <field name="ceo"/>
                    </setting>

                </block>

            </xpath>

        </field>
    </record>
</odoo>