<odoo>
  <data>
    <!-- Extend sale order form view to add custom fields -->
    <record id="view_order_form_custom_reports" model="ir.ui.view">
      <field name="name">sale.order.form.custom.reports</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <!-- Add fields after payment_term_id -->
        <xpath expr="//field[@name='payment_term_id']" position="after">
          <field name="subject"/>
<!--          <field name="att"/>-->
<!--          <field name="location"/>-->
        </xpath>
      </field>
    </record>

    <!-- Move cheque/bank fields from Sale Order to Invoice form -->
    <record id="view_move_form_custom_reports_bank_fields" model="ir.ui.view">
      <field name="name">account.move.form.custom.bank.cheque</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <!-- Add cheque/bank fields right after the journal selection row, without their own group title -->
        <xpath expr="//div[@name='journal_div']" position="after">
          <field name="cheque_no"/>
          <field name="bank_name"/>
        </xpath>
      </field>
    </record>

    <!-- Custom Operations configuration: model, views, menu -->
    <record id="view_sale_custom_operation_tree" model="ir.ui.view">
      <field name="name">sale.custom.operation.list</field>
      <field name="model">sale.custom.operation</field>
      <field name="arch" type="xml">
        <list string="Custom Operations">
          <field name="name"/>
        </list>
      </field>
    </record>

    <record id="view_sale_custom_operation_form" model="ir.ui.view">
      <field name="name">sale.custom.operation.form</field>
      <field name="model">sale.custom.operation</field>
      <field name="arch" type="xml">
        <form string="Custom Operation">
          <sheet>
            <group>
              <field name="name"/>
            </group>
            <notebook>
              <page string="Lines">
                <field name="line_ids">
                  <list editable="bottom">
                    <field name="product_id"/>
                    <field name="name"/>
                    <field name="product_uom_qty"/>
                    <field name="product_uom_id"/>
                    <field name="price_unit"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_sale_custom_operation" model="ir.actions.act_window">
      <field name="name">Custom Operations</field>
      <field name="res_model">sale.custom.operation</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Custom Operations as top-level Sales menu (next to Configuration) -->
    <menuitem id="menu_sale_custom_operation"
              name="Custom Operations"
              parent="sale.sale_menu_root"
              action="action_sale_custom_operation"
              sequence="55"/>

    <!-- Wizard for adding operations to sale order -->
    <record id="view_sale_custom_operation_wizard" model="ir.ui.view">
      <field name="name">sale.custom.operation.wizard.form</field>
      <field name="model">sale.custom.operation.wizard</field>
      <field name="arch" type="xml">
        <form string="Add Operations">
          <group>
            <field name="operation_ids" widget="many2many_tags"/>
          </group>
          <footer>
            <button string="Add" name="action_apply" type="object" class="btn-primary"/>
            <button string="Cancel" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <record id="action_sale_custom_operation_wizard" model="ir.actions.act_window">
      <field name="name">Add Operations</field>
      <field name="res_model">sale.custom.operation.wizard</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="view_sale_custom_operation_wizard"/>
      <field name="target">new</field>
    </record>

    <!-- Control in order lines list toolbar (next to Add a product / Add a section) -->
    <record id="view_order_form_custom_reports_operations" model="ir.ui.view">
      <field name="name">sale.order.form.custom.operations</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='order_line']/list/control" position="inside">
          <button
            string="Add operations"
            name="action_open_add_operations_wizard"
            type="object"
            class="px-4 btn-link"
            context="{'order_id': parent.id}"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
