<odoo>
    <record id="product_template_form_inherit_pick_drop_price" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pick.drop.price</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='list_price_uom']" position="after">
                <field name="pick_up_price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="drop_off_price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>