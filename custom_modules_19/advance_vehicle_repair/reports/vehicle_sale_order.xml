<odoo>
    <template id="report_saleorder_document_inherit_jobcard"
              inherit_id="sale.report_saleorder_document">

        <!-- Target the partner_id contact widget div -->
        <xpath expr="//div[@t-field='doc.partner_id']" position="after">
            <t t-if="doc.jobcard_id">
                <div style="margin-top: 4px; font-size: 12px;">
                    <t t-if="doc.jobcard_id.phone">
                        <div>
                            <strong>Phone: </strong>
                            <span t-field="doc.jobcard_id.phone"/>
                        </div>
                    </t>
                    <t t-if="doc.jobcard_id.registration_no">
                        <div>
                            <strong>Reg No: </strong>
                            <span t-field="doc.jobcard_id.registration_no"/>
                        </div>
                    </t>
                    <t t-if="doc.jobcard_id.brand_id">
                        <div>
                            <strong>Brand: </strong>
                            <span t-field="doc.jobcard_id.brand_id.name"/>
                        </div>
                    </t>
                    <t t-if="doc.jobcard_id.model_id">
                        <div>
                            <strong>Model: </strong>
                            <span t-field="doc.jobcard_id.model_id.name"/>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>

    </template>
</odoo>