<odoo>
    <record id="jobcard_booking_type_wizard_form" model="ir.ui.view">
        <field name="name">jobcard.booking.type.wizard.form</field>
        <field name="model">jobcard.booking.type.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Booking Type">
                <group>
                    <field name="booking_type"/>
                </group>
                <footer>
                    <button name="action_open_jobcard"
                        string="Continue"
                        type="object"
                        class="btn-primary"/>
                    <button string="Cancel"
                        special="cancel"
                        class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>