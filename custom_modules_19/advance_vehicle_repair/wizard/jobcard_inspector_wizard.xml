<odoo>
    <record id="view_select_inspector_wizard_form" model="ir.ui.view">
        <field name="name">select.inspector.wizard.form</field>
        <field name="model">select.inspector.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Inspector">
                <group>
                    <field name="inspector_id"/>
                </group>
                <footer>
                    <button string="Confirm"
                        type="object"
                        name="action_confirm"
                        class="btn-primary"/>
                    <button string="Cancel"
                        special="cancel"
                        class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>