<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record model="ir.module.category" id="advance_vehicle_repair_category">
            <field name="name">Advanced Vehicle Repair</field>
            <field name="sequence">100</field>
        </record>

        <!-- User Groups -->
        <record id="res_groups_privilege_advance_vehicle_repair" model="res.groups.privilege">
            <field name="name">Advanced Vehicle Repair</field>
            <field name="description">Access rights for the Advance Vehicle Repair module</field>
            <field name="sequence">1</field>
            <field name="category_id" ref="advance_vehicle_repair.advance_vehicle_repair_category"/>
        </record>

        <record id="group_vehicle_repair_technician" model="res.groups">
            <field name="name">Technician</field>
            <field name="privilege_id" ref="res_groups_privilege_advance_vehicle_repair"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_vehicle_repair_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_advance_vehicle_repair"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')),(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="group_vehicle_repair_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_advance_vehicle_repair"/>
            <field name="implied_ids" eval="[(4, ref('advance_vehicle_repair.group_vehicle_repair_user'))]"/>
        </record>

        <!--Booking Request-->
        <record id="vehicle_booking_request_user_rule" model="ir.rule">
            <field name="name">Booking - User</field>
            <field name="model_id" ref="model_vehicle_booking_request"/>
            <field name="domain_force">[('responsible_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_user'))]"/>
        </record>

        <record id="vehicle_booking_request_manager_rule" model="ir.rule">
            <field name="name">Booking - Manager</field>
            <field name="model_id" ref="model_vehicle_booking_request"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_manager'))]"/>
        </record>

        <!--Booking-->
        <record id="vehicle_booking_user_rule" model="ir.rule">
            <field name="name">Booking - User</field>
            <field name="model_id" ref="model_vehicle_booking"/>
            <field name="domain_force">[('responsible_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_user'))]"/>
        </record>

        <record id="vehicle_booking_manager_rule" model="ir.rule">
            <field name="name">Booking - Manager</field>
            <field name="model_id" ref="model_vehicle_booking"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_manager'))]"/>
        </record>

        <!--JOb Card-->
        <record id="vehicle_jobcard_manager_rule" model="ir.rule">
            <field name="name">Job Card - Manager</field>
            <field name="model_id" ref="model_vehicle_jobcard"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_manager'))]"/>
        </record>

        <record id="vehicle_jobcard_user_rule" model="ir.rule">
            <field name="name">Job Card - Technician</field>
            <field name="model_id" ref="model_vehicle_jobcard"/>
            <field name="domain_force">[('responsible_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_user'))]"/>
        </record>

        <!--Technician-->
        <record id="vehicle_task_technician_rule" model="ir.rule">
            <field name="name">Task - Technician</field>
            <field name="model_id" ref="model_vehicle_repair_services_line"/>
            <field name="domain_force">[('assigners_user_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_technician'))]"/>
        </record>
        <record id="vehicle_task_user_rule" model="ir.rule">
            <field name="name">Task - User</field>
            <field name="model_id" ref="model_vehicle_repair_services_line"/>
            <field name="domain_force">[('responsible_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_user'))]"/>
        </record>
        <record id="vehicle_task_manager_rule" model="ir.rule">
            <field name="name">Task - Manage</field>
            <field name="model_id" ref="model_vehicle_repair_services_line"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_vehicle_repair_user'))]"/>
        </record>

    </data>

</odoo>