<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vehicle_fuel_tree" model="ir.ui.view">
        <field name="name">vehicle.fuel.type.list</field>
        <field name="model">vehicle.fuel.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="vehicle_fuels_action" model="ir.actions.act_window">
        <field name="name">Fuel Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.fuel.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add and manage your fuel types here!
            </p>
        </field>
    </record>


    <menuitem id="menu_fuels"
              name="Fuel Types"
              parent="menu_vehicle_details"
              action="vehicle_fuels_action"
              sequence="3"/>


</odoo>