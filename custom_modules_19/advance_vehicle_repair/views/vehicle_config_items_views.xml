<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vehicle_items_search" model="ir.ui.view">
        <field name="name">vehicle.items.search</field>
        <field name="model">vehicle.items</field>
        <field name="arch" type="xml">
            <search string="vehicle">
                <field name="name"/>
                <field name="vehicle_category_id"/>
            </search>
        </field>
    </record>

    <record id="vehicle_items_tree" model="ir.ui.view">
        <field name="name">vehicle.items.list</field>
        <field name="model">vehicle.items</field>
        <field name="arch" type="xml">
            <list string="Vehicle Items" editable="bottom">
                <field name="name"/>
                <field name="vehicle_category_id"/>
            </list>
        </field>
    </record>

    <record id="action_vehicle_items" model="ir.actions.act_window">
        <field name="name">Vehicle Item</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.items</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your vehicle items here!
            </p>
        </field>
    </record>

    <menuitem id="menu_items"
              name="Vehicle Items"
              parent="menu_vehicle_conditions"
              action="action_vehicle_items"
              sequence="6"/>

</odoo>