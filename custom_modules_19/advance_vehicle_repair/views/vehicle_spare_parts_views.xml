<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_product_inherit_id" model="ir.ui.view">
        <field name="name">product.product.inheritance</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="spare_part"/>
                    <label for="spare_part"/>
                </span>
                 <span class="d-inline-block d-none">
                    <field name="created_from_service"/>
                    <label for="created_from_service"/>
                </span>
            </xpath>
            <xpath expr="//field[@name='type']" position="after">
                <field name="part_condition" invisible="not spare_part"/>
                <field name="linked_service_id" invisible="not spare_part"/>
            </xpath>
            <xpath expr="//page[@name='general_information']" position="after">
                <page name="vehicle_compatibility" string="Vehicle Compatibility" groups="base.group_user">
                    <field name="vehicle_compatibility_ids">
                        <list editable="bottom">
                            <field name="make_id"/>
                            <field name="model_id" domain="[('brand_id', '=', make_id)]"/>
                            <field name="model_year_ids" widget="many2many_tags"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
    <record id="product_template_inherit_spare_part" model="ir.ui.view">
        <field name="name">product.template.inherit.spare.part</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="spare_part"/>
                    <label for="spare_part"/>
                </span>
            </xpath>
        </field>
    </record>
    <record id="action_inherited_product_product" model="ir.actions.act_window">
        <field name="name">Spare Parts</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('spare_part', '=', True)]</field>
    </record>
    <menuitem id="menu_spare_parts_items"
              name="Spare Parts"
              parent="menu_spare_parts"
              action="action_inherited_product_product"
              sequence="2"/>
</odoo>