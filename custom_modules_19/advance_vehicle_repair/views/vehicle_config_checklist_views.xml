<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="vehicle_checklist_tree" model="ir.ui.view">
            <field name="name">vehicle.checklist.list</field>
            <field name="model">vehicle.checklist</field>
            <field name="arch" type="xml">
                <list string="Checklist Template">
                    <field name="name"/>
                    <field name="checklist_line_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="vehicle_checklist_form" model="ir.ui.view">
            <field name="name">vehicle.checklist.form</field>
            <field name="model">vehicle.checklist</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <label for="name" class="o_form_label">Name:</label>
                                <field name="name"/>
                            </h1>
                        </div>
                        <notebook>
                            <page string="Checklist Items" name="chechklist">
                                <field name="checklist_line_ids">
                                    <list editable="bottom" decoration-bf="display_type == 'line_section'">
                                        <control>
                                            <create name="add_product_control" string="Add a product"/>
                                            <create name="add_section_control" string="Add a section"
                                                    context="{'default_display_type': 'line_section'}"/>
                                        </control>
                                        <field name="name"/>
                                        <field name="display_type" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_vehicle_checklist" model="ir.actions.act_window">
            <field name="name">Checklist Template</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">vehicle.checklist</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Set up your vehicle checklists here!
                </p>
            </field>
        </record>

        <menuitem id="menu_checklist"
                  name="Checklist Templates"
                  parent="menu_configurations"
                  action="action_vehicle_checklist"
                  sequence="8"/>

    </data>
</odoo>