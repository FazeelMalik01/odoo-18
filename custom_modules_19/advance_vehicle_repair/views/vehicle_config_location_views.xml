<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vehicle_location_tree" model="ir.ui.view">
        <field name="name">vehicle.location.list</field>
        <field name="model">vehicle.location</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_vehicle_location" model="ir.actions.act_window">
        <field name="name">Location</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.location</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add and manage your vehicle locations here!
            </p>
        </field>
    </record>

    <menuitem id="menu_location"
              name="Locations"
              parent="menu_vehicle_conditions"
              action="action_vehicle_location"
              sequence="4"/>

</odoo>