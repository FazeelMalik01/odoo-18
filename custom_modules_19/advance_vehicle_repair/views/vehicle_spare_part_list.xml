<odoo>
    <!-- List View -->
    <record id="view_product_vehicle_compatibility_list" model="ir.ui.view">
        <field name="name">product.vehicle.compatibility.list</field>
        <field name="model">product.vehicle.compatibility</field>
        <field name="arch" type="xml">
            <list string="Vehicle Parts List">
                <field name="product_id"/>
                <field name="make_id"/>
                <field name="model_id"/>
                <field name="model_year_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="view_product_vehicle_compatibility_form" model="ir.ui.view">
        <field name="name">product.vehicle.compatibility.form</field>
        <field name="model">product.vehicle.compatibility</field>
        <field name="arch" type="xml">
            <form string="Vehicle Compatibility">
                <sheet>
                    <group>
                        <group string="Product">
                            <field name="product_id" 
                               domain="[('spare_part', '=', True)]"/>
                        </group>
                        <group string="Vehicle Details">
                            <field name="make_id"/>
                            <field name="model_id" 
                               domain="[('brand_id', '=', make_id)]"/>
                            <field name="model_year_ids" 
                               widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_product_vehicle_compatibility_search" model="ir.ui.view">
        <field name="name">product.vehicle.compatibility.search</field>
        <field name="model">product.vehicle.compatibility</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="make_id"/>
                <field name="model_id"/>
                <separator/>
                <filter string="Group by Make"
                    name="group_by_make"
                    context="{'group_by':'make_id'}"/>
            </search>
        </field>
    </record>
    <!-- Action -->
    <record id="action_product_vehicle_compatibility" model="ir.actions.act_window">
        <field name="name">Vehicle Compatibility Matrix</field>
        <field name="res_model">product.vehicle.compatibility</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_vehicle_compatibility_search"/>
        <field name="context">{'group_by': 'make_id'}</field>
    </record>
    <!-- Menu Item — place under your existing Spare Parts / Inventory menu -->
    <menuitem
    id="menu_product_vehicle_compatibility"
    name="Vehicle Parts List"
    parent="menu_spare_parts"
    action="action_product_vehicle_compatibility"
    sequence="20"/>
</odoo>