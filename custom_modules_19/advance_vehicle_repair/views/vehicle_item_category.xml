<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vehicle_item_category_search" model="ir.ui.view">
        <field name="name">vehicle.item.category</field>
        <field name="model">vehicle.item.category</field>
        <field name="arch" type="xml">
            <search string="vehicle">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="vehicle_item_category_tree" model="ir.ui.view">
        <field name="name">vehicle.item.category.list</field>
        <field name="model">vehicle.item.category</field>
        <field name="arch" type="xml">
            <list string="Vehicle Items Category" editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_vehicle_item_category" model="ir.actions.act_window">
        <field name="name">Vehicle Item Category</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.item.category</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your vehicle items here!
            </p>
        </field>
    </record>

    <menuitem id="menu_category"
              name="Vehicle Items Category"
              parent="menu_vehicle_conditions"
              action="action_vehicle_item_category"
              sequence="6"/>

</odoo>