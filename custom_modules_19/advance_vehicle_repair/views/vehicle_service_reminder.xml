<odoo>
    <record id="view_vehicle_service_reminder_tree" model="ir.ui.view">
        <field name="name">vehicle.service.reminder.tree</field>
        <field name="model">vehicle.service.reminder</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="service_id"/>
                <field name="jobcard_id"/>
                <field name="done_date"/>
                <field name="next_due_date"/>
                <field name="recurring_days"/>
            </list>
        </field>
    </record>
    <record id="view_vehicle_service_reminder_form" model="ir.ui.view">
        <field name="name">vehicle.service.reminder.form</field>
        <field name="model">vehicle.service.reminder</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="service_id"/>
                        <field name="jobcard_id"/>
                        <field name="done_date"/>
                        <field name="next_due_date"/>
                        <field name="recurring_days"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_vehicle_service_reminder" model="ir.actions.act_window">
        <field name="name">Service Reminders</field>
        <field name="res_model">vehicle.service.reminder</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem 
        id="menu_vehicle_service_reminder"
        name="Service Reminders"
        parent="menu_services_root"
        action="action_vehicle_service_reminder"
        sequence="2"/>
</odoo>