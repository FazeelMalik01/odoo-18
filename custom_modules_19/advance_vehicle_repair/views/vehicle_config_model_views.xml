<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--    search view-->
    <record id="vehicle_models_search" model="ir.ui.view">
        <field name="name">vehicle.models.search</field>
        <field name="model">vehicle.model</field>
        <field name="arch" type="xml">
            <search string="vehicle">
                <field name="name"/>
                <field name="brand_id"/>
                <group>
                    <filter name="vehiclebrand" string="Vehicle Brand" context="{'group_by':'brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--      Tree view-->
    <record id="vehicle_models_tree" model="ir.ui.view">
        <field name="name">vehicle.models.list</field>
        <field name="model">vehicle.model</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="brand_id"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_vehicle_model" model="ir.actions.act_window">
        <field name="name">Vehicle Model</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.model</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
               Organize your vehicle models here!
            </p>
        </field>
    </record>


    <menuitem id="menu_model"
              name="Models"
              parent="menu_vehicle_details"
              action="action_vehicle_model"
              sequence="2"/>

</odoo>