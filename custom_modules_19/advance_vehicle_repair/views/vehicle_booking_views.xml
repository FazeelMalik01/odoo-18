<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vehicle_booking_activity" model="ir.ui.view">
        <field name="name">vehicle.booking.activity</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <activity string="activity">
                <templates>
                    <div t-name="activity-box">
                        <div>
                            <field name="sequence" display="full"/>
                            <field name="customer_id" muted="1" display="full"/>
                        </div>
                    </div>
                </templates>
            </activity>
        </field>
    </record>
    <record id="vehicle_booking_pivot" model="ir.ui.view">
        <field name="name">vehicle.booking.pivot</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <pivot string="Pivot">
                <field name="brand_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>
    <record id="vehicle_booking_search" model="ir.ui.view">
        <field name="name">vehicle.booking.search</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <search string="Booking">
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="registration_no"/>
                <group>
                    <filter name="vehicle_source" string="Booking Stages" context="{'group_by':'vehicle_source'}"/>
                    <filter name="booking_source" string="Booking Source" context="{'group_by':'booking_source'}"/>
                    <filter name="booking_customer" string="Customer" context="{'group_by':'customer_id'}"/>
                    <filter name="fuel_type" string="Fuel Type" context="{'group_by':'fuel_type_id'}"/>
                    <filter name="brand_vehicle" string="vehicle Brand" context="{'group_by':'brand_id'}"/>
                    <filter name="model_vehicle" string="Vehicle Model" context="{'group_by':'model_id'}"/>
                    <filter name="booking_transmission_type" string="Transmission Type"
                            context="{'group_by':'transmission_type'}"/>
                    <filter name="booking_type" string="Booking Type" context="{'group_by':'booking_type'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="vehicle_booking_kanban" model="ir.ui.view">
        <field name="name">vehicle.booking.kanban</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="customer_id"/>
                <field name="sequence"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="booking_date"/>
                <field name="responsible_id"/>
                <field name="booking_type"/>
                <field name="activity_ids"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title">
                                        <span t-esc="record.brand_id.value"/>
                                        <t t-if="record.brand_id.value and record.model_id.value">
                                            <b>-</b>
                                        </t>
                                        <span t-esc="record.model_id.value"/>
                                    </strong>
                                </div>
                                <strong>
                                    <span t-esc="record.booking_date.value"/>
                                </strong>
                            </div>
                            <div class="o_kanban_tags_section fst-italic">
                                <span t-esc="record.state.value"/>
                            </div>
                            <div class="o_kanban_tags_section oe_kanban_partner_categories">
                                <span t-esc="record.customer_id.value"/>
                            </div>
                            <div class="o_kanban_record_bottom text-muted">
                                <div class="oe_kanban_bottom_left">
                                    <span t-esc="record.sequence.value"/>
                                    <field name="activity_ids" widget="kanban_activity"/>
                                    <span>
                                        <field name="booking_type" widget="label_selection"
                                               options="{'classes': {'vehicle_inspection': 'warning', 'vehicle_repair': 'success', 'both': 'info'}}"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span>
                                        <field name="responsible_id" widget="many2one_avatar_user"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="vehicle_booking_form" model="ir.ui.view">
        <field name="name">vehicle.booking.form</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="vehicle_jobcard_button"
                        string="Create Job Card"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                       />
                    <button 
                        name="booking_cancel_button" 
                        string="Cancel" 
                        type="object" 
                        class="btn-secondary" 
                        invisible="state != 'create'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,create,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="button_open_jobcard" type="object"
                                class="oe_stat_button" icon="fa-bars">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">
                                    <field name="vehicle_jobcard_count"/>
                                    <span> Job Card</span>
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="sequence" readonly="1"/>
                        </h1>
                        <div class="o_vehicle_booking">
                            <field name="vehicle_source" widget="radio" class="horizontal-radio" readonly="state in ['create', 'cancel']"/>
                        </div>
                    </div>
                    <section>
                        <separator string="Vehicle Details"/>
                        <group>
                            <group>
                                <field name="customer_id" readonly="state in ['create', 'cancel']"/>
                                <field name="brand_id" options="{'no_create': True, 'no_open': True}" readonly="state in ['create', 'cancel']"/>
                                <field name="registration_no" readonly="state in ['create', 'cancel']"/>
                            </group>
                            <group>
                                <field name="model_id" options="{'no_create': True, 'no_open': True}" readonly="state in ['create', 'cancel']"/>
                                <field name="fuel_type_id" options="{'no_create': True, 'no_open': True}" readonly="state in ['create', 'cancel']"/>
                                <field name="vin_no" readonly="state in ['create', 'cancel']"/>
                                <field name="transmission_type" widget="radio" class="horizontal-radio" readonly="state in ['create', 'cancel']"/>
                            </group>
                        </group>
                    </section>
                    <section>
                        <separator string="Select Vehicle"/>
                        <group>
                            <group>
                                <field name="vehicle_register_id"
                                    readonly="state in ['create', 'cancel'] or not customer_id" invisible="vehicle_source in ['fleet']" required="vehicle_source == 'register'"  context="{'default_customer_id': customer_id, 'default_registration_no': vehicle_register_id}"/>
                                <field name="vehicle_fleet_id"
                                    readonly="state in ['create', 'cancel']" invisible="vehicle_source in ['register']" required="vehicle_source == 'fleet'"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                                <field name="responsible_id" class="oe_inline" widget="many2one_avatar_user" />
                            </group>
                        </group>
                    </section>
                    <section>
                        <separator string="Customer's Vehicle"/>
                        <field name="customer_vehicle_ids" nolabel="1">
                            <list string="Registered Vehicles">
                                <field name="registration_no"/>
                                <field name="brand_id"/>
                                <field name="model_id"/>
                                <field name="fuel_type_id"/>
                                <field name="vin_no"/>
                                <field name="transmission_type"/>
                            </list>
                        </field>
                    </section>
                    <section>
                        <separator string="Job Card Details"/>
                        <group>
                            <field name="jobcard_id" readonly="1"/>
                        </group>
                    </section>
                    <section  invisible="1">
                        <separator string="Address Details"/>
                        <group>
                            <group>
                                <span class="o_form_label o_td_label" name="address_name">
                                    <b>Address</b>
                                </span>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street" readonly="state in ['create', 'cancel']"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="state in ['create', 'cancel']"/>
                                    <field name="city" placeholder="City" class="o_address_city" readonly="state in ['create', 'cancel']"/>
                                    <field name="state_id" class="o_address_state" placeholder="State" readonly="state in ['create', 'cancel']"/>
                                    <field name="pin_code" placeholder="Pin Code" class="o_address_zip" readonly="state in ['create', 'cancel']"/>
                                    <div name="partner_address_country" class="d-flex justify-content-between">
                                        <field name="country_id" placeholder="Country" class="o_address_country"
                                            options="{'no_create': True, 'no_open': True}" readonly="state in ['create', 'cancel']"/>
                                    </div>
                                </div>
                            </group>
                            <group>
                                <field name="phone" widget="phone" readonly="state in ['create', 'cancel']"/>
                                <field name="email" widget="email" readonly="state in ['create', 'cancel']"/>
                            </group>
                        </group>
                    </section>
                    <section>
                        <separator string="Booking Details"/>
                        <group>
                            <group>
                                <field name="booking_source" widget="radio" class="horizontal-radio" readonly="state in ['create', 'cancel']"/>
                                <field name="booking_type" widget="radio" readonly="state in ['create', 'cancel']"/>
                            </group>
                            <group>
                                <field name="booking_date"/>
                                <field name="available_slot" options="{'no_create': True, 'no_open': True}" readonly="state in ['create', 'cancel']"/>
                            </group>
                        </group>
                    </section>
                    <notebook>
                        <page string="Customer Observations" name="customer_observations">
                            <field name="observations" string="Observations" placeholder="Enter your observations here!" readonly="state in ['create', 'cancel']"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="vehicle_booking_tree" model="ir.ui.view">
        <field name="name">vehicle.booking.list</field>
        <field name="model">vehicle.booking</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'cancel'" decoration-info="state == 'draft'">
                <field name="sequence"/>
                <field name="customer_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="booking_type"/>
                <field name="booking_date" optional="hide"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
                <field name="state" widget="badge"
                        decoration-success="state == 'create'"
                        decoration-info="state == 'draft'"
                        decoration-muted="state == 'cancel'" />
            </list>
        </field>
    </record>
    <record id="action_vehicle_booking" model="ir.actions.act_window">
        <field name="name">Booking</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.booking</field>
        <field name="view_mode">kanban,list,pivot,form,activity</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Book your vehicles here!
            </p>
        </field>
    </record>
    <menuitem 
        id="menu_vehicle_bookings"
        name="Bookings"
        parent="root_vehicle_bookings"
        action="action_vehicle_booking"
        sequence="2"/>
</odoo>