<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="vehicle_jobcards_repair_activity" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.activity</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <activity string="activity">
                    <templates>
                        <div t-name="activity-box">
                            <div>
                                <field name="sequence" display="full"/>
                                <field name="customer_id" muted="1" display="full"/>
                            </div>
                        </div>
                    </templates>
                </activity>
            </field>
        </record>

        <record id="vehicle_jobcards_repair_pivot" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.pivot</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <pivot string="Pivot">
                    <field name="brand_id" type="row"/>
                    <field name="state" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="vehicle_jobcards_repair_search" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.search</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <search string="Repair">
                    <field name="customer_id"/>
                    <field name="brand_id"/>
                    <field name="model_id"/>
                    <field name="state"/>

                    <group>
                        <filter name="brands_sorting" string="Vehicle Brands" context="{'group_by':'brand_id'}"/>
                        <filter name="models_sorting" string="Vehicle Models" context="{'group_by':'model_id'}"/>
                        <filter name="stages_sorting" string="state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="vehicle_jobcards_repair_kanban" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.kanban</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="sequence"/>
                    <field name="brand_id"/>
                    <field name="model_id"/>
                    <field name="booking_date"/>
                    <field name="customer_id"/>
                    <field name="state"/>
                    <field name="responsible_id"/>
                    <field name="activity_ids"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_record_top mb16">
                                    <div class="o_kanban_record_headings mt4">
                                        <strong class="o_kanban_record_title">
                                            <span t-esc="record.sequence.value"/>
                                        </strong>
                                    </div>
                                    <strong>
                                        <span t-esc="record.booking_date.value"/>
                                    </strong>
                                </div>

                                <div class="o_kanban_tags_section oe_kanban_partner_categories">
                                    <div>
                                        <span t-esc="record.brand_id.value"/>
                                        <t t-if="record.brand_id.value and record.model_id.value">
                                            <b>-</b>
                                        </t>
                                        <span t-if="record.model_id" t-esc="record.model_id.value"/>
                                    </div>
                                    <div>
                                        <span t-esc="record.customer_id.value"/>
                                    </div>
                                </div>

                                <div class="o_kanban_record_bottom text-muted">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span>
                                            <field name="responsible_id" widget="many2one_avatar_user"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="vehicle_jobcards_repair_tree" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.list</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <list decoration-muted="state == 'cancel'"
                      decoration-info="state == 'new'">
                    <field name="sequence"/>
                    <field name="inspection_id" column_invisible="True"/>
                    <field name="brand_id"/>
                    <field name="model_id"/>
                    <field name="fuel_type_id" optional="hide"/>
                    <field name="registration_no"/>
                    <field name="customer_id"/>
                    <field name="activity_ids" widget="list_activity" optional="show"/>
                    <field name="booking_date" optional="hide"/>
                    <field name="state" decoration-info="state == 'new'"
                           decoration-primary="state in ('assign_technician', 'diagnosis','supervisor_inspection')"
                           decoration-warning="state == 'hold'"
                           decoration-success="state in ('completed', 'sale_order')"
                           widget="badge"/>
                </list>
            </field>
        </record>

        <record id="vehicle_jobcards_repair_form" model="ir.ui.view">
            <field name="name">vehicle.jobcards.repair.form</field>
            <field name="model">vehicle.jobcards.repair</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button
                                name="action_assign_technician"
                                string="Assign to Technician"
                                attrs="{'invisible':[('state', '!=', 'new'), ('state', '!=', 'cancel')]}"
                                class="btn-primary"
                                type="object"/>

                        <button
                                name="action_in_diagnosis"
                                string="In Diagnosis"
                                attrs="{'invisible': [('state', '!=', 'assign_technician')]}"
                                class="btn-primary"
                                type="object"/>

                        <button
                                name="action_inspection_request"
                                string="Inspection Request"
                                attrs="{'invisible': [('state', '!=', 'diagnosis')]}"
                                class="btn-primary"
                                type="object"/>

                        <button
                                name="action_complete"
                                string="Complete"
                                attrs="{'invisible': [('state', '!=', 'supervisor_inspection')]}"
                                class="btn-primary"
                                type="object"/>

                        <button
                                name="action_hold"
                                string="Hold"
                                attrs="{'invisible': [('state', '!=', 'supervisor_inspection'), ('state', '!=', 'diagnosis')]}"
                                class="btn-warning"
                                type="object"/>

                        <button
                                name="action_unhold"
                                string="Un Hold"
                                attrs="{'invisible': [('state', '!=', 'hold')]}"
                                class="btn-secondary"
                                type="object"/>

                        <button
                                name="action_cancel"
                                string="Cancel"
                                attrs="{'invisible': [('state', '!=', 'supervisor_inspection'), ('state', '!=', 'diagnosis'), ('state', '!=', 'sale_order')]}"
                                class="btn-secondary"
                                type="object"/>

                        <button
                                name="action_create_sale_order"
                                string="Create Sale Order"
                                attrs="{'invisible': [('state', '!=', 'completed')]}"
                                class="btn-primary"
                                type="object"/>

                        <field name="state" widget="statusbar"
                               statusbar_visible="new,assign_technician,diagnosis,supervisor_inspection"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_task" type="object" class="oe_stat_button"
                                    icon="fa-solid fa-tasks" string="Task">
                                <field name="task_count" widget="statinfo"/>
                            </button>
                            <button name="action_view_sale_order" type="object" class="oe_stat_button"
                                    icon="fa-solid fa-file" string="Sale Orders">
                                <field name="sale_order_count" widget="statinfo"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="sequence" readonly="1"/>
                            </h1>
                            <div class="o_vehicle_booking">
                                <field name="vehicle_source" widget="radio" readonly="1" class="horizontal-radio"/>
                            </div>
                        </div>

                        <section string="inspection_jobcard_details">
                            <group>
                                <group>
                                    <separator string="Booking/Inspection Job Card Details"/>
                                    <field name="booking_id" readonly="1"/>
                                    <field name="inspection_id" readonly="1"
                                           attrs="{'invisible' : [('inspection_id', '=', False)]}"/>
                                    <field name="sale_order_id" invisible="1"/>
                                    <field name="company_id" invisible="1"/>
                                    <field name="responsible_id" readonly="0" class="oe_inline"
                                           widget="many2one_avatar_user"/>
                                </group>
                                <group>
                                    <separator string="Inspection/Repair Date"/>
                                    <field name="booking_date"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                </group>
                            </group>
                        </section>

                        <section string="vehicle_details">
                            <separator string="Vehicle Details"/>
                            <group>
                                <group>
                                    <field name="customer_id"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="repair_reg_vehicle"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="brand_id"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="registration_no"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                </group>
                                <group>
                                    <field name="model_id"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="fuel_type_id"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="vin_no"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="transmission_type" widget="radio" class="horizontal-radio"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                </group>
                            </group>
                        </section>

                        <section string="Address Details">
                            <separator string="Address Details"/>
                            <group>
                                <group>
                                    <span class="o_form_label o_td_label" name="address_name">
                                        <b>Address</b>
                                    </span>
                                    <div class="o_address_format">
                                        <field name="street" placeholder="Street..." class="o_address_street"
                                               readonly="0"
                                               attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        <field name="street2" placeholder="Street 2..." class="o_address_street"
                                               readonly="0"
                                               attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        <field name="city" placeholder="City" class="o_address_city"
                                               readonly="0"
                                               attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        <field name="state_id" class="o_address_state" placeholder="State"
                                               readonly="0"
                                               attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        <field name="pin_code" placeholder="Pin Code" class="o_address_zip"
                                               readonly="0"
                                               attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        <div name="partner_address_country" class="d-flex justify-content-between"
                                             readonly="0"
                                             attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}">
                                            <field name="country_id" placeholder="Country" class="o_address_country"
                                                   readonly="0"
                                                   attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                        </div>
                                    </div>
                                </group>
                                <group>
                                    <field name="phone" widget="phone"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                    <field name="email" widget="email"
                                           attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}"/>
                                </group>
                            </group>
                        </section>

                        <notebook>
                            <page string="Customer Observations" name="customer_observations">
                                <field name="observations" string="Observations"
                                       placeholder="Enter your observations here!"/>
                            </page>

                            <page string="Services" name="services">
                                <field name="service_ids"
                                       attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}">
                                    <list editable="bottom" decoration-success="state == 'done'"
                                          decoration-danger="state == 'cancel'">
                                        <field name="repair_id" column_invisible="True"/>
                                        <field name="company_currency" column_invisible="True"/>
                                        <field name="service_id"/>
                                        <field name="service_team"/>
                                        <field name="start_date"/>
                                        <field name="end_date"/>
                                        <field name="state" readonly="1"/>
                                        <field name="service_cost" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                        <button name="action_service_task" class="oe_stat_button" icon="fa-book"
                                                type="object" string="Task"/>
                                        <button name="action_service_assign" class="oe_stat_button" icon="fa-users"
                                                type="object" string="Assign"
                                                attrs="{'invisible': [('state', 'not in', ('draft'))]}"/>
                                    </list>
                                </field>
                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="service_total">
                                        <field name="total_service_charge" nolabel="1" colspan="2" readonly="1"
                                               widget="monetary" options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>

                                <field name="company_currency" invisible="1"/>
                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="total_estimations">
                                        <separator string="Total Estimations"/>
                                        <field name="total_service_charge" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                        <field name="total_parts_charge" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                        <field name="ins" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>
                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="total">
                                        <field name="total_cost" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Vehicle Spare Parts" name="vehicle_spare_parts">
                                <field name="parts_ids"
                                       attrs="{'readonly': [('state', 'in', ('hold', 'completed', 'sale_order'))]}">
                                    <list editable="bottom">
                                        <field name="repair_id" column_invisible="True"/>
                                        <field name="company_currency" column_invisible="True"/>
                                        <field name="spare_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price" readonly="0" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                        <field name="sub_total" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                    </list>
                                </field>
                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="parts_total">
                                        <field name="total_parts_charge" nolabel="1" colspan="2" readonly="1"
                                               widget="monetary" options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>

                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="total_estimations">
                                        <separator string="Total Estimations"/>
                                        <field name="total_service_charge" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                        <field name="total_parts_charge" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>
                                <group name="note_group" col="6" class="mt-2 mt-md-0">
                                    <group class="oe_subtotal_footer oe_right" colspan="2" name="total">
                                        <field name="total_cost" colspan="2" readonly="1" widget="monetary"
                                               options="{'currency_field': 'company_currency'}"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Repair Images" name="repair_images">
                                <field name="image_ids" widget="one2many">
                                    <kanban class="o_kanban_mobile">
                                        <field name="id"/>
                                        <templates>
                                            <t t-name="card">
                                                <div class="oe_kanban_global_click d-flex flex-column oe_kanban_global_area">
                                                    <div class="o_kanban_record_top">
                                                        <div class="o_kanban_component_image"
                                                             style="margin-right: 15px;">
                                                            <div name="document_preview"
                                                                 class="o_kanban_image_wrapper oe_kanban_previewer"
                                                                 title="">
                                                                <div class="inspection_image">
                                                                    <!--                                                                    <img t-att-src="kanban_image('vehicle.repair.image', 'image', record.id.raw_value)"-->
                                                                    <!--                                                                         alt="img" class="inspection-image-size"/>-->
                                                                    <img t-att-src="'/web/image/vehicle.repair.image/' + record.id.raw_value + '/image'"
                                                                         alt="img"
                                                                         class="inspection-image-size"/>

                                                                </div>
                                                                <center>
                                                                    <b>
                                                                        <field name="note"/>
                                                                    </b>
                                                                </center>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                    <form>
                                        <sheet>
                                            <field name="image" widget="image" class="oe_avatar"/>
                                            <group>
                                                <field name="note"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>

                            <page string="Signature" name="signature">
                                <group>
                                    <field name="signed_by"/>
                                    <field name="signature_date"/>
                                    <field name="signature" widget="image"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_vehicle_jobcards_repair" model="ir.actions.act_window">
            <field name="name">Repair Job Card</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">vehicle.jobcards.repair</field>
            <field name="view_mode">kanban,list,pivot,form,activity</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add your repair job cards here!
                </p>
            </field>
        </record>

        <menuitem
                id="menu_jobcards_repair"
                name="Repair Job Cards"
                parent="menu_job_cards"
                action="action_vehicle_jobcards_repair"
                sequence="3"/>

    </data>
</odoo>