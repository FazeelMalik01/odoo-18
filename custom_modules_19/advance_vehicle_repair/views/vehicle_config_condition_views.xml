<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vehicle_condition_tree" model="ir.ui.view">
        <field name="name">vehicle.condition.list</field>
        <field name="model">vehicle.condition</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="short_code"/>
            </list>
        </field>
    </record>

    <record id="vehicle_condition_form" model="ir.ui.view">
        <field name="name">vehicle.condition.form</field>
        <field name="model">vehicle.condition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="short_code"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vehicle_condition" model="ir.actions.act_window">
        <field name="name">Vehicle Condition</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">vehicle.condition</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set up your vehicle conditions here!
            </p>
        </field>
    </record>

    <menuitem id="menu_condition"
              name="Conditions"
              parent="menu_vehicle_conditions"
              action="action_vehicle_condition"
              sequence="5"/>

</odoo>