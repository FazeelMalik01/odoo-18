<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Partners Action & Menu -->
        <record id="action_partner_users" model="ir.actions.act_window">
            <field name="name">Partners</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('group_ids', 'in', [ref('custom_laundry_service.group_partner')])]"/>
        </record>

        <record id="action_partner_users_view_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="base.view_users_tree"/>
            <field name="act_window_id" ref="action_partner_users"/>
        </record>
        
        <record id="action_partner_users_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="base.view_users_form"/>
            <field name="act_window_id" ref="action_partner_users"/>
        </record>

        <menuitem id="menu_partner_users"
                  name="Partners"
                  parent="menu_laundry_configuration_root"
                  action="action_partner_users"
                  sequence="20"/>

        <!-- Customers Action & Menu -->
        <record id="action_customer_users" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
             <field name="domain" eval="[('group_ids', 'in', [ref('custom_laundry_service.group_customer')])]"/>
        </record>
        
        <record id="action_customer_users_view_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="base.view_users_tree"/>
            <field name="act_window_id" ref="action_customer_users"/>
        </record>
        
        <record id="action_customer_users_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="base.view_users_form"/>
            <field name="act_window_id" ref="action_customer_users"/>
        </record>

        <menuitem id="menu_customer_users"
                  name="Customers"
                  parent="menu_laundry_configuration_root"
                  action="action_customer_users"
                  sequence="30"/>
    </data>
</odoo>
