<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add Service Size field to Product Template form view -->
        <record id="product_template_form_view_inherit_service_size" model="ir.ui.view">
            <field name="name">product.template.form.inherit.service.size</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <!-- Add Service Size field after the Product Type field -->
                <xpath expr="//field[@name='type']" position="after">
                    <field name="service_size" 
                           widget="radio" 
                           options="{'horizontal': True}"
                           invisible="type != 'service'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

