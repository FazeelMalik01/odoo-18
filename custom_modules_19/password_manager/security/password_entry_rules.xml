<odoo>
    <record id="password_entry_rule" model="ir.rule">
        <field name="name">Password Entry Access</field>
        <field name="model_id" ref="model_password_entry"/>
        <field name="domain_force">
            ['|',
                ('created_by', '=', user.id),
                ('authorized_user_ids', 'in', user.id)
            ]
        </field>
    </record>
</odoo>
