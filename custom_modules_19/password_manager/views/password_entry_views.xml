<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_password_entry_tree" model="ir.ui.view">
        <field name="name">password.entry.tree</field>
        <field name="model">password.entry</field>
        <field name="arch" type="xml">
            <list string="Password Entries" create="1" delete="1" edit="1">
                <field name="name"/>
                <field name="url"/>
                <field name="username"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="created_by" optional="hide"/>
                <field name="authorized_user_ids" widget="many2many_tags" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_password_entry_form" model="ir.ui.view">
        <field name="name">password.entry.form</field>
        <field name="model">password.entry</field>
        <field name="arch" type="xml">
            <form string="Password Entry">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="url"/>
                            <field name="username"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="authorized_user_ids" widget="many2many_tags"/>
                            <field name="notes"/>
                        </group>
                        <group>
                            <field name="created_by" readonly="1"/>
                            <field name="password" password="True" placeholder="Enter password to save or leave as *** to keep current"/>
                        </group>
                    </group>
                    <group string="Password (view / copy)">
                        <widget name="password_view_copy"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_password_entry_search" model="ir.ui.view">
        <field name="name">password.entry.search</field>
        <field name="model">password.entry</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="url"/>
                <field name="username"/>
                <field name="tag_ids"/>
                <filter string="My Entries" name="my_entries" domain="[('created_by', '=', uid)]"/>
                <filter string="Authorized for me" name="authorized_for_me" domain="[('authorized_user_ids', 'in', uid)]"/>
            </search>
        </field>
    </record>

    <record id="action_password_entry" model="ir.actions.act_window">
        <field name="name">Password Manager</field>
        <field name="res_model">password.entry</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_entries': 1}</field>
        <field name="search_view_id" ref="view_password_entry_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first password entry.
            </p>
            <p>
                Store credentials securely. Only you and users you add as "Authorized Users" can view or copy the password. All access (reveal/copy) is logged in the Chatter.
            </p>
        </field>
    </record>

    <menuitem id="menu_password_root"
              name="Password Manager"
              sequence="30"/>
    <menuitem id="menu_password_entries"
              parent="menu_password_root"
              action="action_password_entry"/>
</odoo>
