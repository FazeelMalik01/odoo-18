<odoo>
    <template id="portal_my_home_inherit_customers"
              inherit_id="portal.portal_my_home"
              priority="50"
              name="Portal My Home - customers Card">

        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-if="request.env.user.sudo().dealer_status == 'approved' and request.env.user.sudo().show_customers_on_portal">
                <div class="o_portal_index_card col-md-6 order-2">
                    <a t-attf-href="/my/customers_list"
                       class="d-flex gap-2 gap-md-3 py-3 pe-md-3 px-md-3 h-100 rounded text-decoration-none bg-100">
                        <div class="o_portal_index_card_icon">
                            <img src="/custom_dealers_portal/static/src/img/customer.png"
                                 alt="customers List"
                                 style="width: 64px; height: 64px;"/>
                        </div>
                        <div>
                            <h5 class="mb-1 fw-normal">Customers</h5>
                            <p class="text-muted mb-0">
                                Access all authorized customers in one place
                            </p>
                        </div>
                    </a>
                </div>
            </t>
        </xpath>

    </template>
</odoo>
