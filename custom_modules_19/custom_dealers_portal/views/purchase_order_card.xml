<odoo>
    <template id="portal_my_home_inherit_purchase" name="Portal My Home - Purchase Orders Card" inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[@id='portal_service_category']" position="inside">
            <t t-if="request.env.user.show_customers_on_portal">
                <div class="o_portal_index_card col-md-6 order-2">
                <a t-attf-href="/my/purchase_orders"
                   class="d-flex gap-2 gap-md-3 py-3 pe-md-3 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_index_card_icon">
                        <img src="/custom_dealers_portal/static/src/img/purchase.png" alt="purchase List" style="width: 64px; height: 64px;"/>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-normal">Purchase Orders</h5>
                        <p class="text-muted mb-0">View and create your purchase orders</p>
                    </div>
                </a>
            </div>
            </t>
        </xpath>
    </template>
</odoo>