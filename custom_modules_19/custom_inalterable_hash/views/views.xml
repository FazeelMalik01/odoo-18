<odoo>
  <data>
    <!-- Extend account move form view to add button for clearing hash and moving to draft -->
    <record id="view_move_form_inherit_inalterable_hash" model="ir.ui.view">
      <field name="name">account.move.form.inherit.inalterable.hash</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <!-- Add button in header to clear hash and move to draft -->
        <xpath expr="//button[@name='button_draft']" position="after">
          <button name="button_draft_clear_hash" 
                  string="Reset to Draft (Clear Hash)" 
                  type="object" 
                  groups="account.group_account_invoice"
                  invisible="state not in ('posted', 'cancel') or not inalterable_hash"
                  class="btn-warning"
                  confirm="This will clear the inalterability hash and reset the entry to draft. Continue?"/>
        </xpath>
      </field>
    </record>
    
